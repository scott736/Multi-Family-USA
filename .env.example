# ─────────────────────────────────────────────────────────────
# DSCR Authority — environment variables
# Copy to `.env` (local) and set the same keys in Vercel for
# Preview + Production via `vercel env add`.
# ─────────────────────────────────────────────────────────────

# --- Site --------------------------------------------------------------
# Canonical origin used to construct absolute URLs in API routes.
SITE=https://dscrauthority.com

# --- Public site phone (US-facing display number) ----------------------
# Set both to override the default in src/consts.ts (currently (989) 662-1099).
# PUBLIC_SITE_PHONE=(800) 555-1234
# PUBLIC_SITE_PHONE_HREF=tel:+18005551234

# --- Analytics ---------------------------------------------------------
# Vercel Web Analytics (@vercel/analytics) — enable in the Vercel project
# dashboard. Custom events (lead_form_submit, phone_click, etc.) use the same package.

# --- Supabase (pending bookings, Nylas grants, lead data) --------------
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only; never exposed to the client.
SUPABASE_SERVICE_KEY=

# --- Nylas (calendar booking) ------------------------------------------
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
# US region by default. Use https://api.eu.nylas.com for EU region.
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_WEBHOOK_SECRET=

# --- Elastic Email (all transactional mail) ----------------------------
# Powers lead-form capture AND Nylas booking confirmations/notifications/
# welcome series. Domain `dscrauthority.com` must be verified in Elastic
# Email before sends from `bookings@dscrauthority.com` will be accepted.
# Lead notifications route to the assigned loan officer (round-robin);
# Lead forms CC scott@lendcity.ca and aya@lendcity.ca on internal notifications;
# confirmed bookings also CC both (see src/lib/lead-inbox.ts).
ELASTIC_EMAIL_API_KEY=

# --- Upstash Redis (rate limiting, grants cache) -----------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Admin -------------------------------------------------------------
# Shared secret used by the /admin/connect-calendar page. Rotate regularly.
ADMIN_CONNECT_KEY=

# Required for /api/crm-webhook-stub (returns 404 when unset).
# CRM_WEBHOOK_SECRET=
