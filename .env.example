# ─────────────────────────────────────────────────────────────
# Multi-Family USA — environment variables
# Copy to `.env` (local) and set the same keys in Vercel for
# Preview + Production via `vercel env add`.
# ─────────────────────────────────────────────────────────────

# --- Site --------------------------------------------------------------
# Canonical origin used to construct absolute URLs in API routes and emails.
SITE=https://multifamily-usa.com

# --- Public site phone (US-facing display number) ----------------------
# Set both to override the default in src/consts.ts (currently (989) 662-1099).
# PUBLIC_SITE_PHONE=(800) 555-1234
# PUBLIC_SITE_PHONE_HREF=tel:+18005551234

# --- Analytics ---------------------------------------------------------
# Vercel Web Analytics (@vercel/analytics) — enable in the Vercel project
# dashboard. Custom events (lead_form_submit, phone_click, etc.) use the same package.

# --- Supabase (pending bookings, lead data) ----------------------------
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only; never exposed to the client.
SUPABASE_SERVICE_KEY=

# --- Nylas (calendar booking) ------------------------------------------
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
# US region by default. Use https://api.eu.nylas.com for EU region.
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_WEBHOOK_SECRET=
# Grant IDs for round-robin scheduling (from Nylas dashboard after OAuth connect)
NYLAS_GRANT_SCOTT=
NYLAS_GRANT_AYA=

# --- Elastic Email (all transactional mail) ----------------------------
# Powers lead-form capture, checklist/analysis emails, and Nylas booking
# confirmations. Domain `multifamily-usa.com` must be verified in Elastic Email
# before sends from the verified sender domain will be accepted.
# Use bookings@dscrauthority.com until multifamily-usa.com is verified in Elastic Email.
ELASTIC_FROM_EMAIL=bookings@dscrauthority.com
ELASTIC_EMAIL_API_KEY=

# --- Upstash Redis (rate limiting) -------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- CRM / Zoho Bigin --------------------------------------------------
# ZOHO_BIGIN_CLIENT_ID=
# ZOHO_BIGIN_CLIENT_SECRET=
# ZOHO_BIGIN_REFRESH_TOKEN=
# ZOHO_BIGIN_REFERRAL_SOURCE=MultiFamilyUSA.com
# SITE=https://multifamily-usa.com
# Optional secondary webhook (Zapier, etc.):
# CRM_WEBHOOK_URL=

# --- Admin (optional) --------------------------------------------------
# Shared secret for future /admin/connect-calendar page.
# ADMIN_CONNECT_KEY=
