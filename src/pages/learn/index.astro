---
import { getCollection } from "astro:content";

import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import CtaCard from "@/components/dscr/CtaCard.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const entries = await getCollection("guides");
---

<DefaultLayout title="Multifamily learning center | Multi-Family USA" description="Core guides covering underwriting, capital markets, and execution.">
  <Breadcrumbs crumbs={[
    { label: "Home", href: "/" },
    { label: "Learn", href: "/learn" },
  ]} />

  <section class="container py-8">
    <p class="text-xs font-bold uppercase tracking-wider text-accent">Learn</p>
    <h1 class="mt-2 text-4xl font-bold lg:text-5xl">Multifamily learning center</h1>
    <p class="mt-4 max-w-3xl text-lg text-muted-foreground">Core guides covering underwriting, capital markets, and execution.</p>
  </section>

  <section class="container py-4">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {entries
        .sort((a, b) => (a.data.title ?? "").localeCompare(b.data.title ?? ""))
        .map((entry) => {
          const slug = entry.id.replace(/\.mdx$/, "");
          return (
            <a href={`/learn/${slug}`} class="group rounded-lg border border-border bg-card p-5 hover:border-accent">
              <h2 class="text-lg font-bold group-hover:text-primary">{entry.data.title}</h2>
              <p class="mt-2 line-clamp-3 text-sm text-muted-foreground">{entry.data.description}</p>
            </a>
          );
        })}
    </div>
  </section>

  <section class="container py-8">
    <h2 class="text-2xl font-bold">Apply these guides across the site</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <a href="/tools/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Run underwriting calculators</h3>
        <p class="mt-2 text-sm text-muted-foreground">Move from concept to numbers with DSCR, debt-yield, and loan-sizing tools.</p>
      </a>
      <a href="/compare/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Compare capital structures</h3>
        <p class="mt-2 text-sm text-muted-foreground">Review agency, bridge, fixed-rate, and recourse trade-offs side by side.</p>
      </a>
      <a href="/states/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Explore market guides</h3>
        <p class="mt-2 text-sm text-muted-foreground">See how state and city market context affects underwriting assumptions.</p>
      </a>
    </div>
  </section>

  <section class="container py-12">
    <CtaCard />
  </section>
</DefaultLayout>
