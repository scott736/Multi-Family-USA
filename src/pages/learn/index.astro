---
import { getCollection } from "astro:content";

import AnswerCapsule from "@/components/dscr/AnswerCapsule.astro";
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import FaqAccordion from "@/components/dscr/FaqAccordion.astro";
import NetworkCrossLinks from "@/components/dscr/NetworkCrossLinks.astro";
import SmartCtaSection from "@/components/sections/SmartCtaSection.astro";
import { buildCollectionPageSchema, buildFaqSchema, buildWebPageSchema, SITE_URL } from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const entries = await getCollection("guides");

const hubFaqs = [
  {
    q: "Where should I start learning multifamily financing?",
    a: "Begin with the apartment building loan guide and commercial DSCR explainer, then pair guides with the calculator suite to test assumptions before requesting lender quotes.",
  },
  {
    q: "Do these guides cover FHA and HUD multifamily programs?",
    a: 'Yes. We publish execution-focused guides on FHA/HUD paths alongside agency, bridge, bank, and CMBS-oriented frameworks. See the <a href="/learn/fha-hud-multifamily-financing/">FHA & HUD guide</a> for program context.',
  },
  {
    q: "Are these guides for 1–4 unit rental properties?",
    a: 'No. This hub covers 5+ unit commercial multifamily. For 1–4 unit US DSCR loans, use <a href="https://dscrauthority.com/" target="_blank" rel="noopener noreferrer">DSCR Authority</a>.',
  },
];

const pageUrl = `${SITE_URL}/learn/`;
const webPageSchema = buildWebPageSchema({
  name: "Multifamily Learning Center",
  description:
    "Guides on apartment building loans, commercial DSCR, agency vs bridge, FHA HUD, construction financing, and multifamily underwriting.",
  url: pageUrl,
});
const collectionSchema = buildCollectionPageSchema({
  name: "Multifamily Learning Center",
  description:
    "Guides on apartment building loans, commercial DSCR, agency vs bridge, FHA HUD, construction financing, and multifamily underwriting.",
  url: pageUrl,
  items: entries.map((entry) => ({
    name: entry.data.title ?? entry.id,
    url: `/learn/${entry.id.replace(/\.mdx$/, "")}/`,
    description: entry.data.description,
  })),
});
const faqSchema = buildFaqSchema(hubFaqs);
---

<DefaultLayout
  title="Multifamily Learning Center — Guides & Execution Playbooks"
  description="Guides on apartment building loans, commercial DSCR, agency vs bridge, FHA HUD, construction financing, and multifamily underwriting."
  canonical="/learn"
  schema={[webPageSchema, collectionSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <Breadcrumbs crumbs={[
    { label: "Home", href: "/" },
    { label: "Learn", href: "/learn" },
  ]} />

  <section class="container py-8">
    <p class="text-xs font-bold uppercase tracking-wider text-accent">Learn</p>
    <h1 class="mt-2 text-4xl font-bold lg:text-5xl">Multifamily learning center</h1>
    <p class="mt-4 max-w-3xl text-lg text-muted-foreground">Core guides covering underwriting, capital markets, and execution.</p>
  </section>

  <section class="container pb-8">
    <AnswerCapsule
      question="What is the Multi-Family USA learning center?"
      answer="Our learning center is a library of execution-focused guides for US commercial multifamily financing — apartment building loans, commercial DSCR, agency and bridge comparisons, FHA/HUD programs, and construction debt for 5+ unit properties."
      bullets={[
        "Plain-English guides for sponsors and operators",
        "Pairs with free underwriting calculators",
        "Updated for agency, bridge, bank, and debt-fund execution",
      ]}
    />
  </section>

  <section class="container py-4">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {entries
        .sort((a, b) => (a.data.title ?? "").localeCompare(b.data.title ?? ""))
        .map((entry) => {
          const slug = entry.id.replace(/\.mdx$/, "");
          return (
            <a href={`/learn/${slug}`} class="group rounded-lg border border-border bg-card p-5 hover:border-accent">
              <h2 class="text-lg font-bold group-hover:text-primary">{entry.data.title}</h2>
              <p class="mt-2 line-clamp-3 text-sm text-muted-foreground">{entry.data.description}</p>
            </a>
          );
        })}
    </div>
  </section>

  <section class="container py-8">
    <h2 class="text-2xl font-bold">Start with these guides</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <a href="/learn/apartment-building-loan-guide/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Apartment building loans</h3>
        <p class="mt-2 text-sm text-muted-foreground">How commercial apartment complex loans work for 5+ units.</p>
      </a>
      <a href="/learn/commercial-dscr-explained/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Commercial DSCR</h3>
        <p class="mt-2 text-sm text-muted-foreground">Lender DSCR calculations and improvement strategies.</p>
      </a>
      <a href="/learn/multifamily-construction-financing/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Construction financing</h3>
        <p class="mt-2 text-sm text-muted-foreground">Ground-up and major rehab multifamily debt.</p>
      </a>
    </div>
  </section>

  <section class="container py-8">
    <h2 class="text-2xl font-bold">Apply these guides across the site</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <a href="/tools/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Run underwriting calculators</h3>
        <p class="mt-2 text-sm text-muted-foreground">Move from concept to numbers with DSCR, debt-yield, and loan-sizing tools.</p>
      </a>
      <a href="/compare/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Compare capital structures</h3>
        <p class="mt-2 text-sm text-muted-foreground">Review agency, bridge, fixed-rate, and recourse trade-offs side by side.</p>
      </a>
      <a href="/states/" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h3 class="text-lg font-bold">Explore market guides</h3>
        <p class="mt-2 text-sm text-muted-foreground">See how state and city market context affects underwriting assumptions.</p>
      </a>
    </div>
  </section>

  <section class="container py-8">
    <NetworkCrossLinks heading="Cross-border and DSCR resources" />
  </section>

  <section class="container py-8">
    <h2 class="text-2xl font-bold">Frequently asked questions</h2>
    <div class="mt-6">
      <FaqAccordion items={hubFaqs} />
    </div>
  </section>

  <SmartCtaSection pathname={Astro.url.pathname} />
</DefaultLayout>
