---
import LeadForm from '@/components/forms/LeadForm.astro';
import { SITE_PHONE, SITE_PHONE_HREF } from '@/consts';
import BasicLayout from '@/layouts/BasicLayout.astro';
---

<BasicLayout
  title="Contact | Multi-Family USA"
  description="Contact Multi-Family USA for multifamily financing questions, deal review follow-ups, and editorial feedback on 5+ unit commercial properties."
  canonical="/contact"
  enPath="/contact/"
  esPath="/es/contact/"
  crumbs={[
    { label: "Home", href: "/" },
    { label: "Contact", href: "/contact" },
  ]}
>
  <h1>Contact</h1>
  <p>Need help with a multifamily financing scenario? Reach out directly.</p>
  <ul>
    <li><a href={SITE_PHONE_HREF}>{SITE_PHONE}</a></li>
    <li><a href="mailto:scott@lendcity.ca">scott@lendcity.ca</a></li>
  </ul>

  <div class="not-prose mt-10">
    <LeadForm
      variant="compact"
      sourceContext="contact-page"
      headline="Request a deal review"
      subheadline="Share your property details and we'll follow up within one business hour."
    />
  </div>
</BasicLayout>
