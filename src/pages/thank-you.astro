---
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const params = Astro.url.searchParams;
const name = params.get("name") || "there";
const assignedOfficer = params.get("assignedOfficer") || "our team";
const state = params.get("state") || "your target market";
const purpose = params.get("purpose") || "your scenario";
---

<DefaultLayout title="Thanks | Multi-Family USA" description="Your deal review request was received.">
  <section class="container py-20">
    <div class="mx-auto max-w-2xl rounded-xl border border-success/30 bg-success/5 p-8">
      <h1 class="text-3xl font-bold">Thanks, {name}.</h1>
      <p class="mt-3 text-muted-foreground">
        Your deal review request is in queue. {assignedOfficer} will follow up shortly with an initial underwriting read.
      </p>
      <dl class="mt-5 grid gap-2 text-sm md:grid-cols-2">
        <div><dt class="text-muted-foreground">Market</dt><dd class="font-semibold">{state}</dd></div>
        <div><dt class="text-muted-foreground">Use case</dt><dd class="font-semibold">{purpose}</dd></div>
      </dl>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/tools" class="rounded-md border border-border px-4 py-2 text-sm font-semibold hover:bg-secondary">Return to tools</a>
        <a href="/book-strategy-call" class="rounded-md bg-accent px-4 py-2 text-sm font-bold text-accent-foreground hover:bg-accent/90">Book a strategy call</a>
      </div>
    </div>
  </section>
</DefaultLayout>
