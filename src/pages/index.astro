---
import ConversionPathHelper from "@/components/conversion/ConversionPathHelper.astro";
import FundedDealsSection from "@/components/sections/FundedDealsSection.astro";
import HomeHero from "@/components/sections/home-hero.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

import { PILLARS, SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<DefaultLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonical="/"
  enPath="/"
  esPath="/es/"
>
  <HomeHero
    eyebrow="US Commercial Multifamily"
    title="Underwrite smarter multifamily deals and compare financing paths with confidence."
    description="Multi-Family USA is a neutral resource for 5+ unit properties. Use the calculator suite, explore state and city coverage, and request a free deal review for agency, bridge, bank, and debt-fund executions."
    ctaPrimary={{ href: "/deal-review", label: "Free Deal Review" }}
    ctaSecondary={{ href: "/book-strategy-call", label: "Book a Strategy Call" }}
    pills={["5+ units only", "No credit pull", "~1 hr response"]}
    formSourceContext="homepage-hero"
  />

  <section class="container py-10">
    <ConversionPathHelper />
  </section>

  <section class="container py-8">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {PILLARS.map((pillar) => (
        <a href={pillar.slug === "markets" ? "/states" : `/${pillar.slug}`} class="rounded-xl border border-border bg-card p-5 hover:border-accent">
          <p class="text-xs font-bold uppercase tracking-wide text-accent">{pillar.tagline}</p>
          <h2 class="mt-2 text-lg font-bold">{pillar.title}</h2>
          <p class="mt-2 text-sm text-muted-foreground">{pillar.description}</p>
        </a>
      ))}
    </div>
  </section>

  <FundedDealsSection />

  <section class="container py-10">
    <div class="rounded-xl border border-border bg-card p-6 md:p-8">
      <h2 class="text-2xl font-bold">What you can do here</h2>
      <ul class="mt-4 grid gap-3 text-sm text-muted-foreground md:grid-cols-2">
        <li>Model NOI, cap rate, debt yield, commercial DSCR, cash-on-cash, and loan sizing.</li>
        <li>Review market-level underwriting context across all 50 states plus DC.</li>
        <li>Compare agency vs bridge, bank vs debt fund, and fixed vs floating structures.</li>
        <li>Send your rent roll assumptions for a free deal review and lender-fit recommendation.</li>
      </ul>
    </div>
  </section>
</DefaultLayout>
