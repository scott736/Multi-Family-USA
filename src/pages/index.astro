---
import LeadForm from "@/components/forms/LeadForm.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

import { PILLARS, SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<DefaultLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonical="/"
  enPath="/"
  esPath="/es/"
>
  <section class="relative overflow-hidden border-b border-border">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-br from-secondary/70 via-background to-accent/[0.05]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute -right-32 top-0 size-[min(28rem,70vw)] rounded-full bg-accent/12 blur-3xl"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute -bottom-24 -left-20 size-80 rounded-full bg-primary/[0.04] blur-3xl"
      aria-hidden="true"
    />

    <div class="container relative py-10 md:py-14 lg:py-16">
      <div class="grid items-center gap-8 lg:grid-cols-[1fr_minmax(0,400px)] lg:gap-10 xl:grid-cols-[1.05fr_420px] xl:gap-12">
        <div class="space-y-7 lg:pr-2">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">US Commercial Multifamily</p>
            <h1 class="mt-3 text-[2.15rem] font-bold leading-[1.08] tracking-tight sm:text-4xl md:text-5xl lg:text-[3.35rem] lg:leading-[1.05]">
              Underwrite smarter multifamily deals and compare financing paths with confidence.
            </h1>
            <p class="mt-5 max-w-xl text-base leading-relaxed text-muted-foreground md:text-lg lg:leading-relaxed">
              Multi-Family USA is a neutral resource for 5+ unit properties. Use the calculator suite,
              explore state and city coverage, and request a free deal review for agency, bridge, bank,
              and debt-fund executions.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href="/deal-review"
              class="inline-flex items-center rounded-xl bg-accent px-6 py-3.5 text-base font-bold text-accent-foreground shadow-md shadow-accent/25 transition hover:bg-accent/90 hover:shadow-lg"
            >
              Free Deal Review
            </a>
            <a
              href="/tools"
              class="inline-flex items-center rounded-xl border border-border bg-card/80 px-6 py-3.5 text-base font-semibold backdrop-blur-sm transition hover:border-primary/20 hover:bg-secondary"
            >
              Explore Tools
            </a>
          </div>

          <div class="flex flex-wrap gap-2.5">
            <span class="inline-flex items-center rounded-full border border-border/80 bg-card/70 px-3.5 py-1.5 text-xs font-semibold text-muted-foreground backdrop-blur-sm">
              5+ units only
            </span>
            <span class="inline-flex items-center rounded-full border border-border/80 bg-card/70 px-3.5 py-1.5 text-xs font-semibold text-muted-foreground backdrop-blur-sm">
              No credit pull
            </span>
            <span class="inline-flex items-center rounded-full border border-border/80 bg-card/70 px-3.5 py-1.5 text-xs font-semibold text-muted-foreground backdrop-blur-sm">
              ~1 hr response
            </span>
          </div>
        </div>

        <div>
          <LeadForm variant="hero" sourceContext="homepage-hero" />
        </div>
      </div>
    </div>
  </section>

  <section class="container py-8">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {PILLARS.map((pillar) => (
        <a href={pillar.slug === "markets" ? "/states" : `/${pillar.slug}`} class="rounded-xl border border-border bg-card p-5 hover:border-accent">
          <p class="text-xs font-bold uppercase tracking-wide text-accent">{pillar.tagline}</p>
          <h2 class="mt-2 text-lg font-bold">{pillar.title}</h2>
          <p class="mt-2 text-sm text-muted-foreground">{pillar.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="container py-10">
    <div class="rounded-xl border border-border bg-card p-6 md:p-8">
      <h2 class="text-2xl font-bold">What you can do here</h2>
      <ul class="mt-4 grid gap-3 text-sm text-muted-foreground md:grid-cols-2">
        <li>Model NOI, cap rate, debt yield, commercial DSCR, cash-on-cash, and loan sizing.</li>
        <li>Review market-level underwriting context across all 50 states plus DC.</li>
        <li>Compare agency vs bridge, bank vs debt fund, and fixed vs floating structures.</li>
        <li>Send your rent roll assumptions for a free deal review and lender-fit recommendation.</li>
      </ul>
    </div>
  </section>
</DefaultLayout>
