---
import { getCollection, render } from "astro:content";

import GuideShell from "@/components/dscr/GuideShell.astro";

export async function getStaticPaths() {
  const entries = await getCollection("investorProfiles");
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const slug = entry.id.replace(/\.mdx$/, "");
const canonicalSlug = `/invest/${slug}`;
---

<GuideShell
  title={data.title}
  description={data.description}
  h1={data.h1 ?? data.title}
  kicker="Invest"
  lastUpdated={data.lastUpdated?.toISOString().slice(0, 10) ?? "2026-05-24"}
  publishedDate={data.published?.toISOString().slice(0, 10)}
  author={data.author}
  reviewer={data.reviewer}
  readTime={data.readTime}
  canonicalSlug={canonicalSlug}
  keywords={data.keywords}
  crumbs={[
    { label: "Home", href: "/" },
    { label: "Invest", href: "/invest" },
    { label: data.title, href: canonicalSlug },
  ]}
  faqs={data.faq}
>
  <Content />
</GuideShell>
