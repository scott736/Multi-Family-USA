---
import { getCollection } from "astro:content";

import AnswerCapsule from "@/components/dscr/AnswerCapsule.astro";
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import CtaCard from "@/components/dscr/CtaCard.astro";
import FaqAccordion from "@/components/dscr/FaqAccordion.astro";
import NetworkCrossLinks from "@/components/dscr/NetworkCrossLinks.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { buildCollectionPageSchema, buildFaqSchema, buildWebPageSchema, SITE_URL } from "@/consts";

const entries = await getCollection("investorProfiles");

const hubFaqs = [
  {
    q: "Who are the investor profiles for?",
    a: "Each playbook maps financing decisions to operator stage — first-time buyers, value-add sponsors, small-portfolio operators, and institutional growth teams — so leverage and product choices match reporting capacity.",
  },
  {
    q: "Should a first-time multifamily buyer start here or in Learn?",
    a: 'Use the <a href="/invest/first-time-multifamily-buyer/">first-time buyer playbook</a> for role-specific sequencing, then dive into Learn guides and Tools calculators for metric depth.',
  },
  {
    q: "Do these playbooks cover Canadian operators buying in the US?",
    a: 'US execution is covered here. For cross-border entity and lender planning from Canada, pair these playbooks with <a href="https://lendcity.ca/cross-border-mortgage-financing/" target="_blank" rel="noopener noreferrer">LendCity cross-border financing</a>.',
  },
];

const pageUrl = `${SITE_URL}/invest/`;
const webPageSchema = buildWebPageSchema({
  name: "Investor Profiles and Playbooks",
  description: "Playbooks for operators at different portfolio stages.",
  url: pageUrl,
});
const collectionSchema = buildCollectionPageSchema({
  name: "Investor Profiles and Playbooks",
  description: "Playbooks for operators at different portfolio stages.",
  url: pageUrl,
  items: entries.map((entry) => ({
    name: entry.data.title ?? entry.id,
    url: `/invest/${entry.id.replace(/\.mdx$/, "")}/`,
    description: entry.data.description,
  })),
});
const faqSchema = buildFaqSchema(hubFaqs);
---

<DefaultLayout
  title="Investor profiles and playbooks | Multi-Family USA"
  description="Playbooks for operators at different portfolio stages."
  canonical="/invest"
  schema={[webPageSchema, collectionSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <Breadcrumbs crumbs={[
    { label: "Home", href: "/" },
    { label: "Invest", href: "/invest" },
  ]} />

  <section class="container py-8">
    <p class="text-xs font-bold uppercase tracking-wider text-accent">Invest</p>
    <h1 class="mt-2 text-4xl font-bold lg:text-5xl">Investor profiles and playbooks</h1>
    <p class="mt-4 max-w-3xl text-lg text-muted-foreground">Playbooks for operators at different portfolio stages.</p>
  </section>

  <section class="container pb-8">
    <AnswerCapsule
      question="What are multifamily investor playbooks?"
      answer="Investor playbooks translate financing strategy to operator stage — how much leverage to use, which loan types fit your business plan, and what reporting and reserve discipline each path requires for 5+ unit US multifamily."
      bullets={[
        "Profiles for first-time buyers through institutional operators",
        "Links to guides, comparisons, and calculators",
        "Execution-focused — not generic investing advice",
      ]}
    />
  </section>

  <section class="container py-4">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {entries
        .sort((a, b) => (a.data.title ?? "").localeCompare(b.data.title ?? ""))
        .map((entry) => {
          const slug = entry.id.replace(/\.mdx$/, "");
          return (
            <a href={`/invest/${slug}`} class="group rounded-lg border border-border bg-card p-5 hover:border-accent">
              <h2 class="text-lg font-bold group-hover:text-primary">{entry.data.title}</h2>
              <p class="mt-2 line-clamp-3 text-sm text-muted-foreground">{entry.data.description}</p>
            </a>
          );
        })}
    </div>
  </section>

  <section class="container py-8">
    <NetworkCrossLinks />
  </section>

  <section class="container py-8">
    <h2 class="text-2xl font-bold">Frequently asked questions</h2>
    <div class="mt-6">
      <FaqAccordion items={hubFaqs} />
    </div>
  </section>

  <section class="container py-12">
    <CtaCard />
  </section>
</DefaultLayout>
