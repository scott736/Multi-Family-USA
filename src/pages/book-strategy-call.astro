---
import BookCallSidebar from "@/components/conversion/BookCallSidebar.astro";
import FaqAccordion from "@/components/dscr/FaqAccordion.astro";
import { SchedulingWidgetWithBoundary } from "@/components/scheduling/scheduling-with-boundary";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { services, teamMembers } from "@/lib/nylas/config";

const service = services.find((s) => s.id === "strategy-call");
const advisorSlug = Astro.url.searchParams.get("advisor");
const initialTeamMember = advisorSlug
  ? teamMembers.find((m) => m.slug === advisorSlug)
  : undefined;

const faqs = [
  {
    q: "Is this a sales call?",
    a: "No. It is a working session to review your 5+ unit scenario, underwriting constraints, and realistic capital-stack paths. There is no credit pull and no obligation to proceed with any lender.",
  },
  {
    q: "What should I prepare?",
    a: "Bring your best rent roll or T-12, target loan amount, purchase price or value, occupancy, and timeline. Even rough numbers are enough to make the call useful.",
  },
  {
    q: "How is this different from a deal review?",
    a: "A deal review is async — you submit numbers and receive a written lender-fit read. A strategy call is live conversation for complex structures, timing questions, or when you want to talk through options before committing assumptions in writing.",
  },
  {
    q: "Who will I meet with?",
    a: "Calls are routed to Chris or Josh — U.S. loan officers on our advisory team. You can choose phone or Microsoft Teams when booking.",
  },
];
---

<DefaultLayout
  title="Book a Strategy Call | Multi-Family USA"
  description="Book a free 30-minute US multifamily financing strategy call—underwriting review, capital-stack options, and execution planning for 5+ unit deals."
  canonical="/book-strategy-call"
  enPath="/book-strategy-call/"
  esPath="/es/book-strategy-call/"
>
  <section class="relative overflow-hidden border-b border-border">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary via-[hsl(215_55%_12%)] to-[hsl(215_50%_8%)]"
      aria-hidden="true"
    />
    <div class="container relative py-10 md:py-14 lg:py-16">
      <div class="grid items-start gap-10 lg:grid-cols-[1fr_minmax(0,420px)] lg:gap-12">
        <div class="space-y-6 text-primary-foreground">
          <p
            class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.2em] text-accent backdrop-blur-md"
          >
            Free · 30 minutes · No credit pull
          </p>
          <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl">
            Book a multifamily <span class="text-accent">strategy call</span>
          </h1>
          <p class="max-w-xl text-lg leading-relaxed text-white/72">
            {service?.description ??
              "Talk through your 5+ unit scenario with a multifamily financing specialist — underwriting constraints, lender-fit paths, and execution timing."}
          </p>
          <ul class="space-y-2 text-sm text-white/70">
            <li>✓ US commercial multifamily (5+ units) only</li>
            <li>✓ Agency, bridge, bank, and debt-fund execution paths</li>
            <li>✓ Phone or Microsoft Teams — your choice</li>
          </ul>
          <p class="text-sm text-white/55">
            Prefer a written read first?
            <a href="/deal-review" class="font-semibold text-accent hover:underline" data-analytics-location="book-page">
              Start a free deal review →
            </a>
          </p>
        </div>
        <div class="hidden lg:block">
          <BookCallSidebar />
        </div>
      </div>
    </div>
  </section>

  <section class="container py-10 md:py-12">
    <div class="lg:hidden mb-8">
      <BookCallSidebar />
    </div>
    <SchedulingWidgetWithBoundary
      client:load
      services={services}
      teamMembers={teamMembers}
      initialServiceId="strategy-call"
      initialTeamMemberId={initialTeamMember?.id}
    />
  </section>

  <section class="container pb-14">
    <h2 class="mb-6 text-2xl font-bold">Frequently asked questions</h2>
    <FaqAccordion items={faqs} />
  </section>
</DefaultLayout>
