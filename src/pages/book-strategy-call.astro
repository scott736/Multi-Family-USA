---
import BasicLayout from "@/layouts/BasicLayout.astro";
import { SchedulingWidgetWithBoundary } from "@/components/scheduling/scheduling-with-boundary";
import { services, teamMembers } from "@/lib/nylas/config";

const service = services.find((s) => s.id === "strategy-call");
---

<BasicLayout
  title="Book a Strategy Call | Multi-Family USA"
  description="Book a 30-minute US multifamily financing strategy call—underwriting review, capital-stack options, and execution planning for 5+ unit deals."
  crumbs={[
    { label: "Home", href: "/" },
    { label: "Book a strategy call", href: "/book-strategy-call" },
  ]}
>
  <div class="mx-auto max-w-3xl space-y-6">
    <div>
      <h1>Book a strategy call</h1>
      <p class="text-muted-foreground">
        {service?.description ??
          "Book a 30-minute call with a multifamily financing specialist."}
      </p>
    </div>

    <SchedulingWidgetWithBoundary
      client:load
      services={services}
      teamMembers={teamMembers}
      initialServiceId="strategy-call"
    />
  </div>
</BasicLayout>
