---
import MaxLoanCalculator from "@/components/calculators/MaxLoanCalculator";
import ToolShell from "@/components/dscr/ToolShell.astro";

const faqs = [
  {
    q: "¿Qué es una calculadora de dimensionamiento de préstamo?",
    a: "Estima proceeds máximos probando DSCR, debt yield y LTV juntos. La restricción vinculante—el monto más bajo—suele fijar la hoja de términos.",
  },
  {
    q: "¿Cómo dimensionan los prestamistas?",
    a: "Calculan el máximo de cada métrica y prestan al resultado más bajo. Modele escenarios base y de estrés.",
  },
  {
    q: "¿Qué restricción vincula más a menudo?",
    a: "Depende del mercado y etapa del activo. En spreads ajustados, debt yield suele vincular en deals estabilizados; value-add puede vincular por DSCR in-place o LTV.",
  },
  {
    q: "¿Debo dimensionar al máximo apalancamiento?",
    a: "No siempre. Máximo apalancamiento reduce equity pero estrecha el margen de covenant.",
  },
  {
    q: "¿Cómo afecta el valor?",
    a: "LTV limita proceeds como porcentaje del valor. NOI impulsa DSCR y debt yield.",
  },
  {
    q: "¿Sirve para agency y bridge?",
    a: "Sí. Cambie supuestos de DSCR, debt yield y LTV por producto y compare proceeds.",
  },
];
---

<ToolShell
  locale="es"
  title="Calculadora de Préstamo Multifamiliar | Multi-Family USA"
  description="Calculadora gratuita de dimensionamiento de préstamo multifamiliar. Encuentre proceeds máximos por DSCR, debt yield y LTV."
  h1="Calculadora de Dimensionamiento de Préstamo"
  toolSlug="loan-sizing-calculator"
  tagline="Calcule deuda máxima soportable desde DSCR, debt yield y LTV—las tres métricas que vinculan la mayoría de hojas de términos."
  keywords={["calculadora préstamo multifamiliar", "dimensionamiento préstamo", "proceeds apartamentos"]}
  relatedGuides={["multifamily-underwriting-basics", "debt-yield-and-ltv-framework", "capital-stack-design-for-value-add"]}
  relatedComparisons={["fixed-vs-floating-rate", "agency-vs-bridge"]}
  faqs={faqs}
>
  <Fragment slot="calculator">
    <MaxLoanCalculator client:load />
  </Fragment>

  <Fragment slot="content">
    <div class="prose prose-neutral max-w-none dark:prose-invert">
      <h2>Cómo dimensionar un préstamo multifamiliar</h2>
      <ul>
        <li><strong>DSCR:</strong> Servicio máx = NOI ÷ DSCR mín</li>
        <li><strong>Debt yield:</strong> Préstamo máx = NOI ÷ debt yield mín</li>
        <li><strong>LTV:</strong> Préstamo máx = Valor × LTV máx</li>
      </ul>

      <h2>Ejemplo: adquisición estabilizada de 56 unidades</h2>
      <p>NOI $980,000; valor $14M; pisos 1.25x DSCR, 9.25% debt yield, 75% LTV. Proceeds probablemente cerca de <strong>$10.5M</strong>.</p>
    </div>
  </Fragment>
</ToolShell>
