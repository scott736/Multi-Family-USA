---
import { buildPersonSchema } from '@/consts';
import { TEAM_MEMBERS } from '@/content/team/members';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { getAuthorBySlug } from '@/lib/authors';

export async function getStaticPaths() {
  return TEAM_MEMBERS.map((member) => ({ params: { slug: member.slug }, props: { member } }));
}

const { member } = Astro.props;
const author = getAuthorBySlug(member.slug);
const initials = member.name
  .split(' ')
  .map((part) => part[0])
  .join('');
const firstName = member.name.split(' ')[0];

const personSchema = author
  ? buildPersonSchema({
      slug: author.slug,
      name: author.name,
      title: author.title,
      bio: author.bio,
      photo: author.photo,
      credentials: author.credentials,
      knowsAbout: author.knowsAbout,
      sameAs: author.sameAs,
    })
  : null;
---

<DefaultLayout
  title={`${member.name} | Multi-Family USA`}
  description={member.shortBio}
  canonical={`/es/team/${member.slug}`}
  enPath={`/team/${member.slug}/`}
  esPath={`/es/team/${member.slug}/`}
  schema={personSchema ? [personSchema] : undefined}
>
  <section class="container py-12 md:py-16">
    <div class="mx-auto max-w-3xl">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        {
          author ? (
            <img
              src={author.photo}
              alt={member.name}
              width={80}
              height={80}
              class="size-20 shrink-0 rounded-full object-cover"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="flex size-20 shrink-0 items-center justify-center rounded-full bg-primary/10 text-2xl font-bold text-primary">
              {initials}
            </span>
          )
        }
        <div>
          <h1 class="text-4xl font-bold">{member.name}</h1>
          <p class="mt-1 text-lg font-semibold text-accent">{member.jobTitle}</p>
          <p class="mt-4 text-muted-foreground leading-relaxed">{member.fullBio}</p>
          {
            member.credentials && member.credentials.length > 0 && (
              <p class="mt-3 text-sm text-muted-foreground">
                {member.credentials.join(" · ")}
              </p>
            )
          }
        </div>
      </div>

      {
        member.knowsAbout.length > 0 && (
          <div class="mt-8">
            <h2 class="text-sm font-bold uppercase tracking-wider text-muted-foreground">Áreas de enfoque</h2>
            <ul class="mt-3 flex flex-wrap gap-2">
              {member.knowsAbout.map((topic) => (
                <li class="rounded-full border border-border bg-secondary/40 px-3 py-1 text-sm">{topic}</li>
              ))}
            </ul>
          </div>
        )
      }

      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href={`/es/book-strategy-call?advisor=${member.slug}`}
          class="inline-flex items-center rounded-md bg-accent px-5 py-2.5 text-sm font-bold text-accent-foreground hover:bg-accent/90"
          data-analytics-location="team-profile-es"
        >
          Reservar una llamada de estrategia con {firstName}
        </a>
        <a href="/es/deal-review" class="inline-flex items-center rounded-md border border-border px-5 py-2.5 text-sm font-semibold hover:bg-secondary">
          Revisión gratuita de deal
        </a>
      </div>
    </div>
  </section>
</DefaultLayout>
