---
import { TEAM_MEMBERS } from "@/content/team/members";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---

<DefaultLayout
  title="Equipo | Multi-Family USA"
  description="Conozca a los colaboradores editoriales y de asesoría detrás de las guías de financiamiento multifamiliar y el soporte de revisión de deals de Multi-Family USA."
  canonical="/es/team"
  enPath="/team/"
  esPath="/es/team/"
>
  <section class="container py-12 md:py-16">
    <h1 class="text-4xl font-bold">Equipo</h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">
      Multi-Family USA combina análisis editorial con experiencia práctica en préstamos y suscripción multifamiliar.
    </p>

    <ul class="mt-10 grid gap-6 md:grid-cols-2">
      {
        TEAM_MEMBERS.map((member) => (
          <li class="rounded-xl border border-border bg-card p-6">
            <div class="flex gap-4">
              <span class="flex size-14 shrink-0 items-center justify-center rounded-full bg-primary/10 text-lg font-bold text-primary">
                {member.name
                  .split(" ")
                  .map((part) => part[0])
                  .join("")}
              </span>
              <div>
                <h2 class="text-xl font-bold">
                  <a href={`/es/team/${member.slug}`} class="hover:text-accent">
                    {member.name}
                  </a>
                </h2>
                <p class="text-sm font-semibold text-accent">{member.jobTitle}</p>
                <p class="mt-2 text-sm text-muted-foreground">{member.shortBio}</p>
              </div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              <a
                href={`/es/team/${member.slug}`}
                class="rounded-md border border-border px-3 py-1.5 text-xs font-semibold hover:bg-secondary"
              >
                Ver perfil
              </a>
              <a
                href={`/es/book-strategy-call?advisor=${member.slug}`}
                class="rounded-md bg-accent px-3 py-1.5 text-xs font-bold text-accent-foreground hover:bg-accent/90"
                data-analytics-location="team-index-es"
              >
                Reservar llamada
              </a>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</DefaultLayout>
