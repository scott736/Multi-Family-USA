---
import { ThankYouBookingSection } from "@/components/conversion/ThankYouBookingSection";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { services, teamMembers } from "@/lib/nylas/config";

const params = Astro.url.searchParams;
const name = params.get("name") || "inversor";
const assignedOfficer = params.get("assignedOfficer") || "";
const state = params.get("state") || "su mercado objetivo";
const purpose = params.get("purpose") || "su escenario";
const validOfficer = teamMembers.some((m) => m.id === assignedOfficer) ? assignedOfficer : undefined;
---

<DefaultLayout
  title="Gracias | Multi-Family USA"
  description="Su solicitud de revisión de deal fue recibida."
  noindex
  enPath="/thank-you/"
  esPath="/es/thank-you/"
>
  <section class="container py-12 md:py-16">
    <div class="mx-auto max-w-3xl">
      <div class="rounded-xl border border-success/30 bg-success/5 p-8">
        <h1 class="text-3xl font-bold">Gracias, {name}.</h1>
        <p class="mt-3 text-muted-foreground">
          Su solicitud de revisión de deal está en cola. Le enviaremos pronto una lectura inicial de suscripción y dirección de encaje con prestamistas.
        </p>
        <dl class="mt-5 grid gap-2 text-sm md:grid-cols-2">
          <div><dt class="text-muted-foreground">Mercado</dt><dd class="font-semibold">{state}</dd></div>
          <div><dt class="text-muted-foreground">Caso de uso</dt><dd class="font-semibold">{purpose}</dd></div>
        </dl>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/es/tools" class="rounded-md border border-border px-4 py-2 text-sm font-semibold hover:bg-secondary">Volver a herramientas</a>
          <a
            href="/es/book-strategy-call"
            class="rounded-md bg-accent px-4 py-2 text-sm font-bold text-accent-foreground hover:bg-accent/90"
            data-analytics-location="thank-you"
          >
            Reservar llamada de estrategia
          </a>
        </div>
      </div>

      <ThankYouBookingSection
        client:load
        services={services}
        teamMembers={teamMembers}
        assignedOfficerId={validOfficer}
        guestName={name}
        lang="es"
      />
    </div>
  </section>
</DefaultLayout>
