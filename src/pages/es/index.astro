---
import LeadForm from "@/components/forms/LeadForm.astro";
import LanguageSwitcher from "@/components/ui/language-switcher";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

import { PILLARS } from "../../consts";

const esTitle = "Multi-Family USA — Recurso de financiamiento multifamiliar comercial";
const esDescription =
  "Recurso independiente de financiamiento multifamiliar comercial en EE. UU. para propiedades de 5+ unidades. Guías, calculadoras y revisión gratuita de operaciones.";
---

<DefaultLayout
  title={esTitle}
  description={esDescription}
  canonical="/es/"
  enPath="/"
  esPath="/es/"
>
  <div class="border-b border-border bg-secondary/30">
    <div class="container flex items-center justify-between py-2">
      <p class="text-xs text-muted-foreground">
        Versión en español · <a href="/" class="underline hover:text-foreground">Ver en inglés</a>
      </p>
      <LanguageSwitcher currentLang="es" enPath="/" esPath="/es/" variant="pill" />
    </div>
  </div>

  <section class="relative overflow-hidden border-b border-border">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-br from-secondary/70 via-background to-accent/[0.05]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute -right-32 top-0 size-[min(28rem,70vw)] rounded-full bg-accent/12 blur-3xl"
      aria-hidden="true"
    />

    <div class="container relative py-14 md:py-20 lg:py-24">
      <div class="grid items-start gap-10 lg:grid-cols-[1fr_minmax(0,480px)] lg:gap-14 xl:grid-cols-[1fr_520px] xl:gap-16">
        <div class="space-y-6 lg:py-2">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">Multifamiliar comercial en EE. UU.</p>
            <h1 class="mt-4 text-4xl font-bold leading-[1.08] tracking-tight md:text-5xl lg:text-[3.15rem]">
              Suscríbe operaciones multifamiliares con más claridad y compara rutas de financiamiento.
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground">
              Multi-Family USA es un recurso neutral para propiedades de 5+ unidades. Usa las calculadoras,
              explora cobertura por estado y ciudad, y solicita una revisión gratuita de tu operación.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href="/deal-review"
              class="inline-flex items-center rounded-xl bg-accent px-5 py-3 text-sm font-bold text-accent-foreground shadow-md shadow-accent/25 transition hover:bg-accent/90 hover:shadow-lg"
            >
              Revisión gratuita
            </a>
            <a
              href="/es/learn"
              class="inline-flex items-center rounded-xl border border-border bg-card/80 px-5 py-3 text-sm font-semibold backdrop-blur-sm transition hover:border-primary/20 hover:bg-secondary"
            >
              Explorar guías
            </a>
          </div>

          <div class="flex flex-wrap gap-2 pt-1">
            <span class="inline-flex items-center rounded-full border border-border/80 bg-card/70 px-3 py-1 text-[11px] font-semibold text-muted-foreground backdrop-blur-sm">
              Solo 5+ unidades
            </span>
            <span class="inline-flex items-center rounded-full border border-border/80 bg-card/70 px-3 py-1 text-[11px] font-semibold text-muted-foreground backdrop-blur-sm">
              Sin consulta de crédito
            </span>
            <span class="inline-flex items-center rounded-full border border-border/80 bg-card/70 px-3 py-1 text-[11px] font-semibold text-muted-foreground backdrop-blur-sm">
              Respuesta ~1 h
            </span>
          </div>
        </div>

        <div class="lg:sticky lg:top-8">
          <LeadForm variant="hero" sourceContext="es-homepage-hero" lang="es" />
        </div>
      </div>
    </div>
  </section>

  <section class="container py-8">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {PILLARS.map((pillar) => (
        <a
          href={pillar.slug === "markets" ? "/es/states" : `/es/${pillar.slug}`}
          class="rounded-xl border border-border bg-card p-5 hover:border-accent"
        >
          <p class="text-xs font-bold uppercase tracking-wide text-accent">{pillar.tagline}</p>
          <h2 class="mt-2 text-lg font-bold">{pillar.title}</h2>
          <p class="mt-2 text-sm text-muted-foreground">{pillar.description}</p>
        </a>
      ))}
    </div>
  </section>
</DefaultLayout>
