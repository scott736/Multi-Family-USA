---
import ConversionPathHelper from "@/components/conversion/ConversionPathHelper.astro";
import FundedDealsSection from "@/components/sections/FundedDealsSection.astro";
import HomeHero from "@/components/sections/home-hero.astro";
import LanguageSwitcher from "@/components/ui/language-switcher";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

import { PILLARS } from "../../consts";

const esTitle = "Multi-Family USA — Recurso de financiamiento multifamiliar comercial";
const esDescription =
  "Recurso independiente de financiamiento multifamiliar comercial en EE. UU. para propiedades de 5+ unidades. Guías, calculadoras y revisión gratuita de operaciones.";
---

<DefaultLayout
  title={esTitle}
  description={esDescription}
  canonical="/es/"
  enPath="/"
  esPath="/es/"
>
  <div class="border-b border-border bg-secondary/30">
    <div class="container flex items-center justify-between py-2">
      <p class="text-xs text-muted-foreground">
        Versión en español · <a href="/" class="underline hover:text-foreground">Ver en inglés</a>
      </p>
      <LanguageSwitcher currentLang="es" enPath="/" esPath="/es/" variant="pill" />
    </div>
  </div>

  <HomeHero
    eyebrow="Multifamiliar comercial en EE. UU."
    title="Suscríbe operaciones multifamiliares con más claridad y compara rutas de financiamiento."
    description="Multi-Family USA es un recurso neutral para propiedades de 5+ unidades. Usa las calculadoras, explora cobertura por estado y ciudad, y solicita una revisión gratuita de tu operación."
    ctaPrimary={{ href: "/es/deal-review", label: "Revisión gratuita" }}
    ctaSecondary={{ href: "/es/book-strategy-call", label: "Reservar llamada" }}
    pills={["Solo 5+ unidades", "Sin consulta de crédito", "Respuesta ~1 h"]}
    formSourceContext="es-homepage-hero"
    stats={[
      { label: "Cobertura", value: "50+", sub: "estados y DC" },
      { label: "Herramientas", value: "20+", sub: "calculadoras" },
      { label: "Respuesta", value: "~1 h", sub: "revisión de operación", accent: true },
    ]}
  />

  <section class="container py-10">
    <ConversionPathHelper locale="es" />
  </section>

  <section class="container py-8">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {PILLARS.map((pillar) => {
        const esCopy = {
          learn: {
            title: "Aprender",
            tagline: "Fundamentos de financiamiento multifamiliar",
            description:
              "Guía clara sobre ejecución agency, bridge, debt fund y banco para multifamiliar.",
          },
          tools: {
            title: "Herramientas",
            tagline: "Calculadoras de suscripción",
            description:
              "Analice NOI, cap rate, DSCR, debt yield, cash-on-cash y dimensionamiento en minutos.",
          },
          markets: {
            title: "Mercados",
            tagline: "Cobertura por estado y ciudad",
            description:
              "Resúmenes de financiamiento multifamiliar en 51 jurisdicciones más instantáneas de ciudad.",
          },
          compare: {
            title: "Comparar",
            tagline: "Decisiones de capital stack",
            description:
              "Compare productos y rutas de ejecución por costo de capital, proceeds y flexibilidad.",
          },
          invest: {
            title: "Invertir",
            tagline: "Playbooks de operador",
            description:
              "Perfiles y marcos de decisión para operadores multifamiliares primerizos e institucionales.",
          },
        }[pillar.slug];
        return (
          <a
            href={pillar.slug === "markets" ? "/es/states" : `/es/${pillar.slug}`}
            class="group flex flex-col rounded-xl border border-border bg-card p-5 transition duration-300 hover:-translate-y-0.5 hover:border-accent/60 hover:shadow-lg hover:shadow-primary/[0.06]"
          >
            <p class="text-xs font-bold uppercase tracking-wide text-accent">{esCopy.tagline}</p>
            <h2 class="mt-2 text-lg font-bold">{esCopy.title}</h2>
            <p class="mt-2 text-sm text-muted-foreground">{esCopy.description}</p>
            <span class="mt-auto inline-flex items-center gap-1 pt-4 text-xs font-semibold text-muted-foreground transition-colors group-hover:text-accent">
              Explorar
              <svg class="size-3.5 transition-transform duration-300 group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        );
      })}
    </div>
  </section>

  <FundedDealsSection lang="es" />
</DefaultLayout>
