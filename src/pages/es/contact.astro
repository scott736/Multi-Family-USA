---
import LeadForm from "@/components/forms/LeadForm.astro";
import { SITE_PHONE, SITE_PHONE_HREF } from "@/consts";
import BasicLayout from "@/layouts/BasicLayout.astro";
---

<BasicLayout
  title="Contacto | Multi-Family USA"
  description="Contacta a Multi-Family USA para preguntas de financiamiento multifamiliar y seguimiento de revisiones de operaciones."
  canonical="/es/contact"
  enPath="/contact/"
  esPath="/es/contact/"
  crumbs={[
    { label: "Inicio", href: "/es" },
    { label: "Contacto", href: "/es/contact" },
  ]}
>
  <h1>Contacto</h1>
  <p>¿Necesitas ayuda con un escenario de financiamiento multifamiliar?</p>
  <div class="not-prose mt-6 grid gap-4 sm:grid-cols-2">
    <a
      href={SITE_PHONE_HREF}
      class="group flex items-center gap-4 rounded-xl border border-border bg-card p-4 !no-underline transition duration-300 hover:-translate-y-0.5 hover:border-accent/60 hover:shadow-md"
    >
      <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </span>
      <span>
        <span class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground">Llamar</span>
        <span class="block font-bold text-foreground group-hover:text-accent">{SITE_PHONE}</span>
      </span>
    </a>
    <a
      href="mailto:scott@lendcity.ca"
      class="group flex items-center gap-4 rounded-xl border border-border bg-card p-4 !no-underline transition duration-300 hover:-translate-y-0.5 hover:border-accent/60 hover:shadow-md"
    >
      <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </span>
      <span>
        <span class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground">Correo</span>
        <span class="block font-bold text-foreground group-hover:text-accent">scott@lendcity.ca</span>
      </span>
    </a>
  </div>

  <div class="not-prose mt-10">
    <LeadForm
      variant="compact"
      sourceContext="es-contact-page"
      headline="Solicitar revisión de operación"
      subheadline="Comparta los detalles de su propiedad y le responderemos en una hora hábil."
      lang="es"
    />
  </div>
</BasicLayout>
