---
import BookCallSidebar from "@/components/conversion/BookCallSidebar.astro";
import ConversionPathHelper from "@/components/conversion/ConversionPathHelper.astro";
import FaqAccordion from "@/components/dscr/FaqAccordion.astro";
import { SchedulingWidgetWithBoundary } from "@/components/scheduling/scheduling-with-boundary";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { services, teamMembers } from "@/lib/nylas/config";

const service = services.find((s) => s.id === "strategy-call");
const advisorSlug = Astro.url.searchParams.get("advisor");
const initialTeamMember = advisorSlug
  ? teamMembers.find((m) => m.slug === advisorSlug)
  : undefined;

const serviceDescriptionEs =
  "Una llamada de 30 minutos para revisar su escenario de 5+ unidades, restricciones de suscripción y rutas probables de financiamiento.";
const localizedServices = services.map((s) =>
  s.id === "strategy-call"
    ? {
        ...s,
        name: "Llamada estratégica multifamiliar gratuita",
        description: serviceDescriptionEs,
      }
    : s,
);

const faqs = [
  {
    q: "¿Es una llamada de ventas?",
    a: "No. Es una sesión de trabajo para revisar su escenario de 5+ unidades, restricciones de suscripción y rutas realistas de capital. Sin consulta de crédito ni obligación de avanzar con ningún prestamista.",
  },
  {
    q: "¿Qué debo preparar?",
    a: "Traiga su rent roll o T-12, monto de préstamo objetivo, precio o valor, ocupación y cronograma. Incluso números aproximados son suficientes.",
  },
  {
    q: "¿En qué se diferencia de una revisión de deal?",
    a: "La revisión es asíncrona — envía números y recibe una lectura escrita. La llamada es conversación en vivo para estructuras complejas, timing o cuando quiere hablar opciones antes de formalizar supuestos.",
  },
  {
    q: "¿Con quién hablaré?",
    a: "Las llamadas se enrutan a Scott o Aya del equipo de asesoría multifamiliar. Puede elegir teléfono o Microsoft Teams al reservar.",
  },
];
---

<DefaultLayout
  title="Reservar llamada de estrategia | Multi-Family USA"
  description="Reserve una llamada gratuita de 30 minutos sobre financiamiento multifamiliar comercial en EE. UU. — suscripción, opciones de capital y planificación de ejecución."
  canonical="/es/book-strategy-call"
  enPath="/book-strategy-call/"
  esPath="/es/book-strategy-call/"
>
  <section class="relative overflow-hidden border-b border-border">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary via-[hsl(215_55%_12%)] to-[hsl(215_50%_8%)]"
      aria-hidden="true"
    />
    <div class="container relative py-10 md:py-14 lg:py-16">
      <div class="grid items-start gap-10 lg:grid-cols-[1fr_minmax(0,420px)] lg:gap-12">
        <div class="space-y-6 text-primary-foreground">
          <p
            class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.2em] text-accent backdrop-blur-md"
          >
            Gratis · 30 min · Sin consulta de crédito
          </p>
          <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl">
            Reserve una <span class="text-accent">llamada de estrategia</span> multifamiliar
          </h1>
          <p class="max-w-xl text-lg leading-relaxed text-white/72">
            {serviceDescriptionEs}
          </p>
          <ul class="space-y-2 text-sm text-white/70">
            <li>✓ Solo multifamiliar comercial en EE. UU. (5+ unidades)</li>
            <li>✓ Rutas agency, puente, banco y debt fund</li>
            <li>✓ Teléfono o Microsoft Teams — usted elige</li>
          </ul>
          <p class="text-sm text-white/55">
            ¿Prefiere una lectura escrita primero?
            <a href="/es/deal-review" class="font-semibold text-accent hover:underline" data-analytics-location="book-page">
              Iniciar revisión gratuita →
            </a>
          </p>
        </div>
        <div class="hidden lg:block">
          <BookCallSidebar locale="es" />
        </div>
      </div>
    </div>
  </section>

  <section class="container py-10 md:py-12">
    <div class="grid gap-10 lg:grid-cols-[1fr_minmax(0,420px)] lg:gap-12">
      <div class="min-w-0">
        <SchedulingWidgetWithBoundary
          client:load
          services={localizedServices}
          teamMembers={teamMembers}
          initialServiceId="strategy-call"
          initialTeamMemberId={initialTeamMember?.id}
          lang="es"
        />
      </div>
      <aside class="space-y-6 lg:sticky lg:top-24">
        <div class="lg:hidden">
          <BookCallSidebar locale="es" />
        </div>
        <ConversionPathHelper locale="es" />
      </aside>
    </div>
  </section>

  <section class="container pb-14">
    <h2 class="mb-6 text-2xl font-bold">Preguntas frecuentes</h2>
    <FaqAccordion items={faqs} />
  </section>
</DefaultLayout>
