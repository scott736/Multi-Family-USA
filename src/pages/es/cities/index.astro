---
import { getCollection } from "astro:content";

import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import SmartCtaSection from "@/components/sections/SmartCtaSection.astro";
import { buildCollectionPageSchema, buildWebPageSchema, SITE_URL } from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const entries = await getCollection("esCities");
const pageUrl = `${SITE_URL}/es/cities/`;
const webPageSchema = buildWebPageSchema({
  name: "Ciudades multifamiliares de primer nivel",
  description: "Instantáneas de financiamiento multifamiliar a nivel de ciudad para mercados de primer nivel en EE. UU.",
  url: pageUrl,
  inLanguage: "es-US",
});
const collectionSchema = buildCollectionPageSchema({
  name: "Ciudades multifamiliares de primer nivel",
  description: "Instantáneas de financiamiento multifamiliar a nivel de ciudad para mercados de primer nivel en EE. UU.",
  url: pageUrl,
  items: entries.map((entry) => ({
    name: entry.data.cityName ?? entry.id,
    url: `/es/cities/${entry.id.replace(/\.mdx$/, "")}/`,
    description: entry.data.description,
  })),
});
---

<DefaultLayout
  title="Ciudades multifamiliares de primer nivel | Multi-Family USA"
  description="Instantáneas de financiamiento multifamiliar a nivel de ciudad para mercados de primer nivel en EE. UU."
  canonical="/es/cities"
  enPath="/cities/"
  esPath="/es/cities/"
  schema={[webPageSchema, collectionSchema]}
>
  <Breadcrumbs crumbs={[
    { label: "Inicio", href: "/es" },
    { label: "Ciudades", href: "/es/cities" },
  ]} />

  <section class="container py-8">
    <p class="text-xs font-bold uppercase tracking-wider text-accent">Guías de ciudad</p>
    <h1 class="mt-2 text-4xl font-bold lg:text-5xl">Instantáneas de ciudades multifamiliares de primer nivel</h1>
    <p class="mt-4 max-w-3xl text-lg text-muted-foreground">
      Instantáneas de mercado para los principales metros multifamiliares con contexto típico de cap rate y renta por unidad.
    </p>
  </section>

  <section class="container py-4">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {entries
        .sort((a, b) => (a.data.cityName ?? "").localeCompare(b.data.cityName ?? ""))
        .map((entry) => {
          const slug = entry.id.replace(/\.mdx$/, "");
          return (
            <a href={`/es/cities/${slug}`} class="rounded-lg border border-border bg-card p-5 hover:border-accent">
              <h2 class="text-lg font-bold">{entry.data.cityName}, {entry.data.stateCode}</h2>
              <p class="mt-2 text-sm text-muted-foreground">{entry.data.description}</p>
              <p class="mt-3 text-xs text-muted-foreground">
                Cap rate típico {entry.data.typicalCapRate.toFixed(1)}% · Mediana $/unidad ${entry.data.medianPricePerUnit.toLocaleString()}
              </p>
            </a>
          );
        })}
    </div>
  </section>

  <SmartCtaSection pathname={Astro.url.pathname} />
</DefaultLayout>
