---
import { BarChart3, Clock, Landmark, ShieldCheck, Sparkles, TrendingUp } from "lucide-react";

import ConversionPathHelper from "@/components/conversion/ConversionPathHelper.astro";
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import LeadForm from "@/components/forms/LeadForm.astro";
import FundedDealsSection from "@/components/sections/FundedDealsSection.astro";
import { buildServiceSchema, SITE_URL } from "@/consts";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

const schema = buildServiceSchema({
  name: "Revisión gratuita de deal multifamiliar",
  description:
    "Envíe supuestos de su operación de 5+ unidades y reciba recomendación de encaje con prestamistas, puntos de suscripción y opciones de ejecución.",
  url: `${SITE_URL}/es/deal-review/`,
});

const benefits = [
  {
    icon: Landmark,
    title: "Encaje por tipo de prestamista",
    detail: "Rutas agency, banco, puente y debt fund según su escenario.",
  },
  {
    icon: BarChart3,
    title: "Instantánea de suscripción",
    detail: "LTV, DSCR y debt yield con restricciones de apalancamiento.",
  },
  {
    icon: TrendingUp,
    title: "Claridad de ejecución",
    detail: "Enrutamiento según cronograma antes de pedir term sheets.",
  },
];
---

<DefaultLayout
  title="Revisión gratuita de deal | Multi-Family USA"
  description="Obtenga una revisión gratuita de suscripción y encaje con prestamistas para su operación multifamiliar de 5+ unidades en EE. UU."
  schema={[schema]}
  canonical="/es/deal-review"
  enPath="/deal-review/"
  esPath="/es/deal-review/"
>
  <Breadcrumbs
    crumbs={[
      { label: "Inicio", href: "/es" },
      { label: "Revisión gratuita", href: "/es/deal-review" },
    ]}
  />

  <section class="relative overflow-hidden border-b border-border">
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary via-[hsl(215_55%_12%)] to-[hsl(215_50%_8%)]"
      aria-hidden="true"
    />
    <div class="container relative py-10 md:py-16 lg:py-20">
      <div class="grid items-start gap-12 lg:grid-cols-[1fr_minmax(0,520px)] lg:gap-14 xl:grid-cols-[1fr_540px] xl:gap-20">
        <div class="space-y-8 text-primary-foreground">
          <div>
            <p
              class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.2em] text-accent backdrop-blur-md"
            >
              <Sparkles class="size-3.5" />
              Gratis · Sin consulta de crédito
            </p>
            <h1 class="mt-6 text-4xl font-bold leading-[1.08] tracking-tight md:text-5xl lg:text-[3.35rem]">
              Su operación multifamiliar, con <span class="text-accent">claridad de encaje</span>
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/72">
              Comparta supuestos una vez. Devolvemos restricciones de apalancamiento, puntos de presión DSCR y debt yield,
              y rutas de capital que valen la pena — usualmente en una hora hábil.
            </p>
          </div>

          <ul class="space-y-4">
            {
              benefits.map(({ icon: Icon, title, detail }) => (
                <li class="flex gap-4 rounded-2xl border border-white/10 bg-white/[0.06] p-4 backdrop-blur-sm">
                  <span class="flex size-11 shrink-0 items-center justify-center rounded-xl bg-accent/20 text-accent">
                    <Icon class="size-5" />
                  </span>
                  <div>
                    <p class="font-semibold text-white">{title}</p>
                    <p class="mt-0.5 text-sm leading-relaxed text-white/65">{detail}</p>
                  </div>
                </li>
              ))
            }
          </ul>

          <div class="grid grid-cols-3 gap-3 sm:gap-4">
            <div class="rounded-2xl border border-white/10 bg-white/[0.06] px-3 py-4 text-center backdrop-blur-sm">
              <p class="text-2xl font-bold text-accent">5+</p>
              <p class="mt-1 text-[10px] font-semibold uppercase tracking-wider text-white/55">Solo unidades</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/[0.06] px-3 py-4 text-center backdrop-blur-sm">
              <p class="text-2xl font-bold text-accent">$0</p>
              <p class="mt-1 text-[10px] font-semibold uppercase tracking-wider text-white/55">Sin crédito</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/[0.06] px-3 py-4 text-center backdrop-blur-sm">
              <Clock class="mx-auto size-6 text-accent" />
              <p class="mt-1 text-[10px] font-semibold uppercase tracking-wider text-white/55">~1 h respuesta</p>
            </div>
          </div>
        </div>

        <div class="lg:sticky lg:top-8">
          <LeadForm
            variant="premium"
            sourceContext="es-deal-review-page"
            headline="Inicie su revisión gratuita"
            subheadline="Cuatro pasos rápidos. Lectura en vivo de LTV, DSCR y debt yield."
            submitLabel="Enviar para revisión"
            lang="es"
          />
        </div>
      </div>
    </div>
  </section>

  <FundedDealsSection lang="es" />

  <section class="container py-10">
    <ConversionPathHelper locale="es" />
  </section>
</DefaultLayout>
