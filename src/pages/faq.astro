---
import AnswerCapsule from "@/components/dscr/AnswerCapsule.astro";
import { buildFaqSchema, buildWebPageSchema, SITE_URL } from "@/consts";
import BasicLayout from "@/layouts/BasicLayout.astro";

const faqPageUrl = `${SITE_URL}/faq/`;
const webPageSchema = buildWebPageSchema({
  name: "Multifamily Financing FAQ",
  description:
    "Expert answers on US multifamily underwriting, DSCR, debt yield, bridge vs agency execution, and lender sizing for 5+ unit commercial properties.",
  url: faqPageUrl,
});

const faqItems = [
  {
    q: "What types of properties are covered?",
    a: 'Multi-Family USA covers US commercial multifamily properties with five or more units. We do not publish lending guidance for one-to-four-unit residential lending—for that scope, see our sister site <a href="https://dscrauthority.com/" target="_blank" rel="noopener noreferrer">DSCR Authority</a>.',
  },
  {
    q: "Do you cover financing outside the United States?",
    a: "No. Our content focuses only on US lending programs, lender behavior, and execution strategy for US markets.",
  },
  {
    q: "What metrics do lenders use to size multifamily loans?",
    a: "Most lenders underwrite DSCR, debt yield, and leverage together. Proceeds are usually determined by whichever metric is most constraining after lender-specific adjustments.",
  },
  {
    q: "Why can lender proceeds differ from my model?",
    a: "Lenders may normalize NOI differently, apply market-specific stress assumptions, and include reserve requirements that lower available proceeds versus a sponsor model.",
  },
  {
    q: "How should I prepare before requesting term sheets?",
    a: "Prepare lender-ready in-place and stabilized NOI views, support major assumptions, and include downside sensitivity for occupancy, expenses, and refinance rates.",
  },
  {
    q: "When does bridge debt make sense?",
    a: "Bridge debt can be useful for transitional business plans when sponsors can clearly support renovation pacing, lease-up timelines, reserve strategy, and refinance path.",
  },
  {
    q: "What creates most closing delays?",
    a: "Delays are commonly caused by late diligence package assembly, unresolved entity and guarantor documentation, and assumptions that change during credit review.",
  },
  {
    q: "What should operators track after close?",
    a: "Monthly reporting should include occupancy, effective rents, concessions, bad debt, expense variance, capex pacing, and covenant headroom with written variance commentary.",
  },
];

const faqSchema = buildFaqSchema(faqItems);
---

<BasicLayout
  title="Multifamily Financing FAQ | Multi-Family USA"
  description="Expert answers on US multifamily underwriting, DSCR, debt yield, bridge vs agency execution, and lender sizing for 5+ unit commercial properties."
  schema={[webPageSchema, ...(faqSchema ? [faqSchema] : [])]}
  canonical="/faq"
  enPath="/faq/"
  esPath="/es/faq/"
  crumbs={[
    { label: "Home", href: "/" },
    { label: "FAQ", href: "/faq" },
  ]}
>
  <h1>FAQ</h1>
  <AnswerCapsule
    question="What is US commercial multifamily financing?"
    answer="US commercial multifamily financing is debt for income-producing apartment properties with five or more units. Lenders size loans on property NOI using DSCR, debt yield, and LTV—not residential debt-to-income rules. Common products include agency (Fannie/Freddie), bridge, bank balance sheet, CMBS, and FHA/HUD programs."
    bullets={[
      "5+ units only — not 1–4 unit residential DSCR",
      "Proceeds bind to the tightest of DSCR, debt yield, and LTV",
      "Entity borrowing and guarantor diligence are standard",
    ]}
  />

  <p class="mt-6">
    Answers to common questions on US commercial multifamily financing for 5+ unit
    properties. This page is educational and does not replace transaction-specific legal,
    tax, or lending advice.
  </p>

  <h2>Scope and definitions</h2>
  <h3>{faqItems[0].q}</h3>
  <p set:html={faqItems[0].a} />

  <h3>{faqItems[1].q}</h3>
  <p>{faqItems[1].a}</p>

  <h2>Qualification and debt sizing</h2>
  <h3>{faqItems[2].q}</h3>
  <p>{faqItems[2].a}</p>

  <h3>{faqItems[3].q}</h3>
  <p>{faqItems[3].a}</p>

  <h3>{faqItems[4].q}</h3>
  <p>{faqItems[4].a}</p>

  <h2>Execution and risk management</h2>
  <h3>{faqItems[5].q}</h3>
  <p>{faqItems[5].a}</p>

  <h3>{faqItems[6].q}</h3>
  <p>{faqItems[6].a}</p>

  <h3>{faqItems[7].q}</h3>
  <p>{faqItems[7].a}</p>

  <h2>How to use this site</h2>
  <p>
    Start with the <a href="/learn">Learn</a> library for core frameworks, then use
    <a href="/tools">Tools</a> to test assumptions and <a href="/states">States</a> or
    <a href="/cities">Cities</a> pages for market context. If you want execution feedback
    on a live deal, use the <a href="/deal-review">free deal review</a>.
  </p>
</BasicLayout>
