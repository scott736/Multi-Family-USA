---
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---

<DefaultLayout
  title="Multifamily Checklists & Templates | Multi-Family USA"
  description="Free multifamily pro forma and due diligence checklists for US commercial 5+ unit acquisitions, refinances, and lender-ready underwriting."
  canonical="/checklists"
>
  <Breadcrumbs
    crumbs={[
      { label: "Home", href: "/" },
      { label: "Checklists", href: "/checklists" },
    ]}
  />
  <section class="container py-12">
    <h1 class="text-4xl font-bold">Multifamily checklists and templates</h1>
    <p class="mt-3 max-w-3xl text-muted-foreground">
      Practical resources for US commercial multifamily financing on 5+ unit properties.
      Use these pages to understand how each template supports underwriting quality, lender
      communication, and execution discipline.
    </p>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <a href="/checklists/pro-forma-template" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h2 class="text-xl font-bold">Multifamily Pro Forma Template</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          Underwriting framework with in-place and stabilized NOI views, debt-sizing scenarios,
          and refinance stress testing.
        </p>
      </a>
      <a href="/checklists/due-diligence-checklist" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h2 class="text-xl font-bold">Due Diligence Checklist</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          Closing-readiness framework covering legal, operating, physical, lease, and financing
          diligence for acquisitions and refinances.
        </p>
      </a>
    </div>

    <div class="mt-10 max-w-3xl rounded-lg border border-border bg-card p-6">
      <h2 class="text-2xl font-bold">How to use these resources</h2>
      <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm text-muted-foreground">
        <li>Start with your in-place operating data and avoid unsupported assumptions.</li>
        <li>Run base and downside underwriting cases before requesting lender quotes.</li>
        <li>Use the checklist to assign owners and due dates for diligence workstreams.</li>
        <li>Keep documentation current through closing and into post-close reporting.</li>
      </ol>
    </div>
  </section>
</DefaultLayout>
