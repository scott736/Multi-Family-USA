---
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---

<DefaultLayout title="Lead Magnets | Multi-Family USA" description="Downloadable multifamily underwriting templates and checklists.">
  <section class="container py-12">
    <h1 class="text-4xl font-bold">Lead magnets</h1>
    <p class="mt-3 text-muted-foreground">Launch placeholders for gated resources.</p>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <a href="/checklists/pro-forma-template" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h2 class="text-xl font-bold">Multifamily Pro Forma Template</h2>
        <p class="mt-2 text-sm text-muted-foreground">Starter underwriting model with stabilized and bridge-to-stabilized scenarios.</p>
      </a>
      <a href="/checklists/due-diligence-checklist" class="rounded-lg border border-border bg-card p-5 hover:border-accent">
        <h2 class="text-xl font-bold">Due Diligence Checklist</h2>
        <p class="mt-2 text-sm text-muted-foreground">Operational, legal, capex, and financing diligence checklist for 5+ unit acquisitions.</p>
      </a>
    </div>
  </section>
</DefaultLayout>
