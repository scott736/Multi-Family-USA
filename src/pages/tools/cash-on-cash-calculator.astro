---
import CashOnCashCalculator from "@/components/calculators/CashOnCashCalculator";
import ToolShell from "@/components/dscr/ToolShell.astro";
---

<ToolShell
  title="Cash-on-Cash Calculator | Multi-Family USA"
  description="Estimate annual equity return on commercial multifamily investments."
  h1="Cash-on-Cash Calculator"
  toolSlug="cash-on-cash-calculator"
  tagline="Evaluate annual net cash flow against your total equity investment."
  relatedGuides={["capital-stack-design-for-value-add", "operator-reporting-for-lenders", "multifamily-underwriting-basics"]}
  relatedComparisons={["bank-vs-debt-fund", "recourse-vs-nonrecourse"]}
  relatedInvestorProfiles={["value-add-sponsor", "small-portfolio-operator"]}
>
  <Fragment slot="calculator">
    <CashOnCashCalculator client:load />
  </Fragment>
</ToolShell>
