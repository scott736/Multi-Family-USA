---
import CapRateNoiCalculator from "@/components/calculators/CapRateNoiCalculator";
import ToolShell from "@/components/dscr/ToolShell.astro";
---

<ToolShell
  title="Cap Rate and NOI Calculator | Multi-Family USA"
  description="Estimate NOI and cap rate for 5+ unit multifamily opportunities."
  h1="Cap Rate & NOI Calculator"
  toolSlug="cap-rate-noi-calculator"
  tagline="Model stabilized income, operating expenses, and implied market cap rates."
  relatedGuides={["multifamily-noi-normalization", "stabilized-vs-transitional-assets", "multifamily-underwriting-basics"]}
  relatedComparisons={["bank-vs-debt-fund", "agency-vs-bridge"]}
  relatedPropertyTypes={["garden-style-multifamily", "value-add-c-class-multifamily"]}
>
  <Fragment slot="calculator">
    <CapRateNoiCalculator client:load />
  </Fragment>
</ToolShell>
