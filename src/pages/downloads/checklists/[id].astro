---
import { getChecklist, VALID_CHECKLIST_IDS } from '@/lib/checklists/checklist-data';

export function getStaticPaths() {
  return VALID_CHECKLIST_IDS.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const checklist = getChecklist(id!);

if (!checklist) {
  return Astro.redirect('/checklists');
}

const lang = Astro.url.searchParams.get('lang') === 'es' ? 'es' : 'en';
const isEs = lang === 'es';
const title = isEs ? checklist.titleEs : checklist.titleEn;
const sections = isEs ? checklist.sectionsEs : checklist.sectionsEn;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title} — Printable</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Georgia, 'Times New Roman', serif;
        line-height: 1.5;
        color: #111827;
      }
      body {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
      }
      h1 {
        font-size: 1.75rem;
        margin: 0 0 0.5rem;
        line-height: 1.2;
      }
      .meta {
        color: #6b7280;
        font-size: 0.875rem;
        margin-bottom: 2rem;
      }
      h2 {
        font-size: 1.125rem;
        margin: 1.75rem 0 0.5rem;
        border-bottom: 1px solid #e5e7eb;
        padding-bottom: 0.25rem;
      }
      ul {
        margin: 0.5rem 0 0;
        padding-left: 1.25rem;
      }
      li {
        margin: 0.35rem 0;
      }
      .print-hint {
        margin-top: 2rem;
        padding: 0.75rem 1rem;
        background: #f3f4f6;
        border-radius: 0.5rem;
        font-size: 0.875rem;
      }
      @media print {
        .print-hint,
        .no-print {
          display: none !important;
        }
        body {
          padding: 0;
        }
      }
    </style>
  </head>
  <body>
    <p class="no-print print-hint">
      {isEs
        ? 'Use Archivo → Imprimir o Guardar como PDF para descargar esta lista.'
        : 'Use File → Print or Save as PDF to download this checklist.'}
    </p>

    <h1>{title}</h1>
    <p class="meta">
      {isEs ? 'Multi-Family USA · Lista imprimible' : 'Multi-Family USA · Printable checklist'}
    </p>

    {
      sections.map((section) => (
        <section>
          <h2>{section.title}</h2>
          <ul>
            {section.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </body>
</html>
