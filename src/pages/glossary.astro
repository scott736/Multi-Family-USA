---
import {
  buildDefinedTermSetSchema,
  buildWebPageSchema,
  SITE_URL,
} from "@/consts";
import BasicLayout from "@/layouts/BasicLayout.astro";
import { GLOSSARY_LETTER_GROUPS, GLOSSARY_TERMS_EN } from "@/lib/glossary-terms";

const pageUrl = `${SITE_URL}/glossary/`;
const description =
  "Definitions of DSCR, debt yield, NOI, cap rate, and capital-markets terms used in US commercial multifamily financing (5+ units).";
const webPageSchema = buildWebPageSchema({
  name: "Multifamily Financing Glossary",
  description,
  url: pageUrl,
});
const definedTermSchema = buildDefinedTermSetSchema({
  name: "Multifamily Financing Glossary",
  description,
  url: pageUrl,
  terms: GLOSSARY_TERMS_EN.map((t) => ({ term: t.term, definition: t.definition })),
});
---

<BasicLayout
  title="Multifamily Financing Glossary | Multi-Family USA"
  description={description}
  canonical="/glossary"
  enPath="/glossary/"
  esPath="/es/glossary/"
  schema={[webPageSchema, definedTermSchema]}
  crumbs={[
    { label: "Home", href: "/" },
    { label: "Glossary", href: "/glossary" },
  ]}
>
  <h1>Glossary</h1>
  <p>
    Core US commercial multifamily financing terms used across our guides, tools, and
    market pages for 5+ unit properties.
  </p>

  {
    GLOSSARY_LETTER_GROUPS.map((group) => {
      const terms = GLOSSARY_TERMS_EN.filter((t) => t.letterGroup === group);
      return (
        <>
          <h2>{group}</h2>
          {terms.map((t) => (
            <p>
              <strong>{t.term}:</strong> {t.definition}
            </p>
          ))}
        </>
      );
    })
  }
</BasicLayout>
