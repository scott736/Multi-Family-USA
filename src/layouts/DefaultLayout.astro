---
import BaseHead from "@/components/BaseHead.astro";
import TopBanner from "@/components/sections/banner.astro";
import { Footer } from "@/components/sections/footer";
import Navbar from "@/components/sections/navbar.astro";
import StickyMobileCta from "@/components/sections/sticky-mobile-cta.astro";
import { pageLangFromPath } from "@/i18n/alternates";

import { getBaseSchemas } from "../consts";

interface AlternateLink {
  hreflang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  canonical?: string;
  keywords?: string[];
  alternates?: AlternateLink[];
  enPath?: string;
  esPath?: string;
  includeSpanish?: boolean;
}

const {
  title,
  description,
  image,
  schema,
  noindex,
  canonical,
  keywords,
  alternates,
  enPath,
  esPath,
  includeSpanish,
} = Astro.props;

const htmlLang = pageLangFromPath(Astro.url.pathname) === "es" ? "es-US" : "en-US";

const schemaArray = Array.isArray(schema) ? schema : schema ? [schema] : [];
const allSchemas = [...getBaseSchemas(), ...schemaArray];
---

<html lang={htmlLang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
      canonical={canonical}
      keywords={keywords}
      alternates={alternates}
      enPath={enPath}
      esPath={esPath}
      includeSpanish={includeSpanish}
    />
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("theme");
          const dark = saved
            ? saved === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch {}
      })();
    </script>
    {
      allSchemas.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }
  </head>
  <body class="min-h-screen antialiased">
    <TopBanner />
    <Navbar currentPath={Astro.url.pathname} enPath={enPath} esPath={esPath} />
    <main data-pagefind-body><slot /></main>
    <div class="cv-auto">
      <Footer currentPath={Astro.url.pathname} />
    </div>
    <StickyMobileCta currentPath={Astro.url.pathname} />
    <script>
      import "@/scripts/analytics-tracker";
    </script>
  </body>
</html>
