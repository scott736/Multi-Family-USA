---
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";

import DefaultLayout from "./DefaultLayout.astro";

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  crumbs?: Crumb[];
}

const { title, description, image, noindex, canonical, schema, crumbs } = Astro.props;
---

<DefaultLayout
  title={title}
  description={description}
  image={image}
  noindex={noindex}
  canonical={canonical}
  schema={schema}
>
  {crumbs && crumbs.length > 0 && <Breadcrumbs crumbs={crumbs} />}
  <section class="mx-auto max-w-3xl px-4 py-16 md:py-24">
    <article class="prose-dscr">
      <slot />
    </article>
  </section>
</DefaultLayout>
