---
interface Props {
  locale?: "en" | "es";
  className?: string;
}

const { locale = "en", className = "" } = Astro.props;
const isEs = locale === "es";
const dealReviewHref = isEs ? "/es/deal-review" : "/deal-review";
const bookHref = isEs ? "/es/book-strategy-call" : "/book-strategy-call";
---

<div
  class:list={[
    "rounded-2xl border border-border bg-card p-5 md:p-6",
    className,
  ]}
>
  <p class="text-xs font-bold uppercase tracking-wider text-accent">
    {isEs ? "¿Qué camino le conviene?" : "Which path fits you?"}
  </p>
  <div class="mt-4 grid gap-4 md:grid-cols-2">
    <a
      href={dealReviewHref}
      class="group flex items-start gap-4 rounded-xl border border-border p-4 transition duration-300 hover:-translate-y-0.5 hover:border-accent/60 hover:bg-secondary/40 hover:shadow-md hover:shadow-primary/[0.05]"
      data-analytics-location="conversion-path-helper"
    >
      <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent transition-colors group-hover:bg-accent/15">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="M18 17V9M13 17V5M8 17v-3"/>
        </svg>
      </span>
      <span>
        <p class="inline-flex items-center gap-1.5 font-bold text-foreground group-hover:text-accent">
          {isEs ? "Revisión gratuita del deal" : "Free deal review"}
          <svg class="size-3.5 opacity-0 transition-all duration-300 group-hover:translate-x-0.5 group-hover:opacity-100" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </p>
        <p class="mt-1 text-sm text-muted-foreground">
          {isEs
            ? "Tiene números y quiere una lectura escrita de encaje con prestamistas (~1 h)."
            : "You have numbers and want a written lender-fit read — usually within one business hour."}
        </p>
      </span>
    </a>
    <a
      href={bookHref}
      class="group flex items-start gap-4 rounded-xl border border-border p-4 transition duration-300 hover:-translate-y-0.5 hover:border-accent/60 hover:bg-secondary/40 hover:shadow-md hover:shadow-primary/[0.05]"
      data-analytics-location="conversion-path-helper"
    >
      <span class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent transition-colors group-hover:bg-accent/15">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </span>
      <span>
        <p class="inline-flex items-center gap-1.5 font-bold text-foreground group-hover:text-accent">
          {isEs ? "Llamada de estrategia" : "Strategy call"}
          <svg class="size-3.5 opacity-0 transition-all duration-300 group-hover:translate-x-0.5 group-hover:opacity-100" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </p>
        <p class="mt-1 text-sm text-muted-foreground">
          {isEs
            ? "Quiere hablar en vivo sobre estructura, timing o un escenario complejo (30 min)."
            : "You want to talk through structure, timing, or a complex scenario live — 30 minutes."}
        </p>
      </span>
    </a>
  </div>
</div>
