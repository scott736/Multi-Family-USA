---
import "../styles/global.css";

import { buildHreflangAlternates, ensureTrailingSlash, pageLangFromPath } from "@/i18n/alternates";

import { SITE_METADATA, SITE_URL } from "../consts";

interface AlternateLink {
  hreflang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  keywords?: string[];
  /** Extra alternates (merged with auto hreflang when not disabled). */
  alternates?: AlternateLink[];
  /** Override English path for hreflang (trailing slash optional). */
  enPath?: string;
  /** Override Spanish path for hreflang (trailing slash optional). */
  esPath?: string;
  /** When false, omit es-US alternate (page has no Spanish counterpart). */
  includeSpanish?: boolean;
  /** When true, skip auto hreflang (caller supplies full alternates). */
  disableAutoHreflang?: boolean;
}

const {
  title,
  description,
  image,
  noindex,
  canonical,
  keywords,
  alternates = [],
  enPath,
  esPath,
  includeSpanish = true,
  disableAutoHreflang = false,
} = Astro.props;

const pageLang = pageLangFromPath(Astro.url.pathname);
const finalTitle = title || SITE_METADATA.title.default;
const finalDescription = description || SITE_METADATA.description;
const ogImage = SITE_METADATA.openGraph.images[0];
const finalImage = image || ogImage.url;

const canonicalPath = canonical
  ? ensureTrailingSlash(canonical.startsWith("http") ? new URL(canonical).pathname : canonical)
  : ensureTrailingSlash(Astro.url.pathname);

const canonicalUrl = new URL(canonicalPath, Astro.site);
const ogImageUrl = new URL(finalImage, Astro.site);

const autoAlternates = disableAutoHreflang
  ? []
  : buildHreflangAlternates(SITE_URL, {
      pathname: Astro.url.pathname,
      enPath,
      esPath,
      includeSpanish,
    });

const hreflangLinks = disableAutoHreflang ? alternates : [...autoAlternates, ...alternates];

const robotsParts = [
  noindex ? "noindex" : "index",
  SITE_METADATA.robots.follow ? "follow" : "nofollow",
  "max-snippet:-1",
  "max-image-preview:large",
  "max-video-preview:-1",
];
---

<link rel="preconnect" href="https://vitals.vercel-insights.com" crossorigin />
<link rel="dns-prefetch" href="https://vitals.vercel-insights.com" />

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<meta name="robots" content={robotsParts.join(", ")} />
<meta name="googlebot" content={robotsParts.join(", ")} />
<meta name="description" content={finalDescription} />
<meta name="author" content={SITE_METADATA.authors[0].name} />
<meta name="generator" content={Astro.generator} />

<title>{finalTitle}</title>
<link rel="canonical" href={canonicalUrl} />
{
  hreflangLinks.map((alt) => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
  ))
}

<meta property="og:type" content="website" />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content={String(ogImage.width)} />
<meta property="og:image:height" content={String(ogImage.height)} />
<meta property="og:image:alt" content={ogImage.alt} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:locale" content={pageLang === "es" ? "es_US" : SITE_METADATA.openGraph.locale} />
{pageLang === "es" && <meta property="og:locale:alternate" content="en_US" />}
{pageLang === "en" && includeSpanish && <meta property="og:locale:alternate" content="es_US" />}

<meta name="twitter:card" content={SITE_METADATA.twitter.card} />
<meta name="twitter:site" content={SITE_METADATA.twitter.site} />
<meta name="twitter:creator" content={SITE_METADATA.twitter.creator} />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={ogImage.alt} />

<link rel="alternate" type="application/rss+xml" title="Multi-Family USA Blog RSS" href="/rss.xml" />
<link rel="alternate" type="text/plain" title="LLMs Index" href="/llms.txt" />
<link rel="alternate" type="text/plain" title="LLMs Full" href="/llms-full.txt" />
<link rel="author" type="text/plain" href="/humans.txt" />
