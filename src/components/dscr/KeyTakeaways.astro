---
// KeyTakeaways — a TL;DR block designed for AI/AEO extraction.
// Renders a semantic <aside> with data-speakable so the Article's
// SpeakableSpecification (in GuideShell) picks it up, and a <dl> list
// that both humans and LLMs parse cleanly.
import { getLangFromUrl } from "@/i18n/utils";

interface Props {
  title?: string;
  points: string[];
  id?: string;
}

const lang = getLangFromUrl(Astro.url);
const isEs = lang === "es";
const defaultTitle = isEs ? "Puntos clave" : "Key takeaways";

const { title = defaultTitle, points, id = "key-takeaways" } = Astro.props;
---

<aside
  id={id}
  aria-label={title}
  class="not-prose my-8 rounded-xl border border-accent/30 bg-accent/5 p-6"
  data-speakable
>
  <p class="text-xs font-bold uppercase tracking-wider text-accent">{title}</p>
  <ul class="mt-3 space-y-2 text-sm leading-relaxed text-foreground">
    {points.map((p) => (
      <li class="flex gap-2">
        <span aria-hidden="true" class="mt-0.5 text-accent">•</span>
        <span>{p}</span>
      </li>
    ))}
  </ul>
</aside>
