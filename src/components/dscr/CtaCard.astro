---
import LeadForm from "@/components/forms/LeadForm.astro";

interface Props {
  headline?: string;
  subheadline?: string;
  sourceContext?: string;
  variant?: "full" | "compact";
}

const {
  headline = "Get a free multifamily deal review",
  subheadline = "Share your property details once. We will return a lender-fit and underwriting read within one business hour.",
  sourceContext,
  variant = "full",
} = Astro.props;
---

<div
  class:list={[
    "rounded-2xl bg-gradient-to-br from-accent/40 via-border to-primary/25 p-[1px] shadow-xl shadow-primary/[0.08]",
    variant === "compact" ? "my-0" : "my-12",
  ]}
>
  <LeadForm
    variant={variant}
    headline={headline}
    subheadline={subheadline}
    sourceContext={sourceContext}
    className="border-transparent shadow-none"
  />
</div>
