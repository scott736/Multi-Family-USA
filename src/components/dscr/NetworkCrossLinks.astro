---
interface LinkItem {
  href: string;
  title: string;
  description: string;
  external?: boolean;
}

interface Props {
  heading?: string;
  intro?: string;
}

const {
  heading = "Related resources in the LendCity network",
  intro = "Multi-Family USA is part of the Scott Dillingham / LendCity editorial network. Use these sister sites when your scenario spans US DSCR, Canadian multifamily, or cross-border capital.",
} = Astro.props;

const links: LinkItem[] = [
  {
    href: "https://dscrauthority.com/",
    title: "DSCR Authority",
    description: "US DSCR loans for 1–4 unit rental properties — calculators, state guides, and free lender matching.",
    external: true,
  },
  {
    href: "https://lendcity.ca/multifamily-mortgage-financing/",
    title: "LendCity — Canadian multifamily & CMHC MLI",
    description: "CMHC MLI Select, insured multifamily, and cross-border financing for Canadian operators investing in the US.",
    external: true,
  },
  {
    href: "https://lendcity.ca/cross-border-mortgage-financing/",
    title: "LendCity — Cross-border financing",
    description: "Guidance for Canadians buying US rental and multifamily property, including entity and lender-fit planning.",
    external: true,
  },
];
---

<section class="rounded-2xl border border-border bg-card p-6 md:p-8">
  <h2 class="text-2xl font-bold">{heading}</h2>
  <p class="mt-3 max-w-3xl text-sm leading-relaxed text-muted-foreground">{intro}</p>
  <div class="mt-5 grid gap-4 md:grid-cols-3">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="group rounded-lg border border-border bg-background p-5 transition hover:border-accent"
          {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >
          <h3 class="text-base font-bold group-hover:text-accent">{link.title}</h3>
          <p class="mt-2 text-sm text-muted-foreground">{link.description}</p>
        </a>
      ))
    }
  </div>
</section>
