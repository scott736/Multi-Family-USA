---
interface Props {
  question: string;
  answer: string;
  bullets?: string[];
  label?: string;
}

const { question, answer, bullets = [], label = "Quick answer" } = Astro.props;
---

<section
  role="note"
  aria-label={label}
  data-aeo-answer="true"
  class="rounded-xl border border-accent/30 bg-accent/5 p-5 md:p-6"
>
  <p class="text-xs font-bold uppercase tracking-wider text-accent">{label}</p>
  <h2 class="mt-2 text-lg font-bold text-foreground md:text-xl">{question}</h2>
  <p class="mt-3 text-sm leading-relaxed text-muted-foreground md:text-base">{answer}</p>
  {
    bullets.length > 0 && (
      <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-2">
            <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
    )
  }
</section>
