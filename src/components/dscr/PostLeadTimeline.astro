---
import { CheckCircle2, Clock, FileText, Phone } from "lucide-react";

interface Props {
  lang?: "en" | "es";
  bookCallHref?: string;
}

const { lang = "en", bookCallHref = "/book-strategy-call" } = Astro.props;
const isEs = lang === "es";

const steps = isEs
  ? [
      {
        title: "Revisión en curso (próxima hora)",
        body: "Un especialista DSCR con licencia revisa tu escenario y consulta nuestra red de prestamistas.",
      },
      {
        title: "Ofertas indicativas (mismo día hábil)",
        body: "Recibirás hasta 3 ofertas DSCR comparables — tasa, comisiones, penalización por prepago y plazo de cierre.",
      },
      {
        title: "Prepara documentos",
        body: "Reúne los documentos habituales antes de tu llamada para acelerar la suscripción.",
      },
      {
        title: "Elige prestamista y solicita",
        body: "Compara ofertas, elige la que encaje y presenta la solicitud formal — sin presión de nuestro equipo.",
      },
    ]
  : [
      {
        title: "Review in progress (next hour)",
        body: "A licensed DSCR specialist is reviewing your scenario against our lender network.",
      },
      {
        title: "Indicative offers (same business day)",
        body: "You'll receive up to 3 competing DSCR offers — rate, fees, prepay penalty, and close timeline.",
      },
      {
        title: "Gather documents",
        body: "Pull together standard docs before your call so underwriting can move faster.",
      },
      {
        title: "Choose a lender & apply",
        body: "Compare offers, pick the best fit, and submit a formal application — no pressure from our team.",
      },
    ];

const heading = isEs ? "Qué sigue" : "What happens next";
const checklistLabel = isEs ? "Lista de verificación antes de aplicar" : "Before You Apply checklist";
const docLabel = isEs ? "Lista de documentos" : "Document checklist";
const bookLabel = isEs ? "Prefieres hablar ahora? Agenda una llamada" : "Prefer to talk now? Book a strategy call";
---

<div class="rounded-2xl border border-border bg-card p-6 md:p-8 shadow-sm">
  <h2 class="text-xl md:text-2xl font-bold text-foreground flex items-center gap-2">
    <Clock className="size-5 text-accent" />
    {heading}
  </h2>

  <ol class="mt-6 space-y-5">
    {
      steps.map((step, i) => (
        <li class="flex gap-4">
          <span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-accent/15 text-sm font-bold text-accent">
            {i + 1}
          </span>
          <div>
            <h3 class="font-semibold text-foreground">{step.title}</h3>
            <p class="mt-1 text-sm text-muted-foreground">{step.body}</p>
          </div>
        </li>
      ))
    }
  </ol>

  <div class="mt-8 grid gap-3 sm:grid-cols-2">
    <a
      href={isEs ? "/es/checklists" : "/checklists"}
      class="flex items-start gap-3 rounded-xl border border-border bg-secondary/30 p-4 hover:bg-secondary/50 transition-colors"
    >
      <CheckCircle2 className="size-5 shrink-0 text-success mt-0.5" />
      <div>
        <span class="text-sm font-semibold text-foreground">{checklistLabel}</span>
        <p class="mt-0.5 text-xs text-muted-foreground">
          {isEs
            ? "Imprimible — sin correo requerido."
            : "Printable — no email required."}
        </p>
      </div>
    </a>
    <a
      href={isEs ? "/es/learn/document-checklist" : "/learn/document-checklist"}
      class="flex items-start gap-3 rounded-xl border border-border bg-secondary/30 p-4 hover:bg-secondary/50 transition-colors"
    >
      <FileText className="size-5 shrink-0 text-primary mt-0.5" />
      <div>
        <span class="text-sm font-semibold text-foreground">{docLabel}</span>
        <p class="mt-0.5 text-xs text-muted-foreground">
          {isEs
            ? "Todo lo que la mayoría de prestamistas DSCR solicitan."
            : "Everything most DSCR lenders ask for."}
        </p>
      </div>
    </a>
  </div>

  <div class="mt-6 text-center">
    <a
      href={isEs ? "/es/book-strategy-call" : bookCallHref}
      class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
    >
      <Phone className="size-4" />
      {bookLabel}
    </a>
  </div>
</div>
