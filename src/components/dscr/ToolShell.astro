---
import AnswerCapsule from "@/components/dscr/AnswerCapsule.astro";
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import CtaCard from "@/components/dscr/CtaCard.astro";
import FaqAccordion from "@/components/dscr/FaqAccordion.astro";
import RelatedReading from "@/components/dscr/RelatedReading.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { getOgImageForKind } from "@/lib/og-image";
import { getRelatedLinks } from "@/lib/related-links";

import { buildFaqSchema, buildWebPageSchema, SITE_URL } from "../../consts";

interface Faq {
  q: string;
  a: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  toolSlug: string;
  kicker?: string;
  tagline?: string;
  lastUpdated?: string;
  faqs?: Faq[];
  extraSchema?: Record<string, unknown> | Array<Record<string, unknown>>;
  keywords?: string[];
  relatedGuides?: string[];
  relatedComparisons?: string[];
  relatedLoanTypes?: string[];
  relatedPropertyTypes?: string[];
  relatedInvestorProfiles?: string[];
  relatedBlog?: string[];
  locale?: "en" | "es";
  enPath?: string;
  esPath?: string;
}

const {
  title,
  description,
  h1,
  toolSlug,
  kicker,
  tagline,
  lastUpdated = "2026-05-24",
  faqs = [],
  extraSchema,
  keywords,
  relatedGuides,
  relatedComparisons,
  relatedLoanTypes,
  relatedPropertyTypes,
  relatedInvestorProfiles,
  relatedBlog,
  locale = "en",
  enPath,
  esPath,
} = Astro.props;

const isEs = locale === "es";
const faqList = Array.isArray(faqs) ? faqs : [];
const toolPath = isEs ? `/es/tools/${toolSlug}` : `/tools/${toolSlug}`;
const canonicalUrl = `${SITE_URL}${toolPath}`;
const resolvedKicker = kicker ?? (isEs ? "Herramienta interactiva" : "Interactive tool");
const resolvedEnPath = enPath ?? `/tools/${toolSlug}/`;
const resolvedEsPath = esPath ?? `/es/tools/${toolSlug}/`;
const faqHeading = isEs ? "Preguntas frecuentes" : "Frequently asked questions";
const relatedHeading = isEs ? "Recursos relacionados" : "Related Resources";
const lastUpdatedLabel = isEs ? "Última actualización:" : "Last updated:";
const ctaHeadline = isEs
  ? "¿Necesita una lectura de suscripción real?"
  : "Need a real-world underwriting read?";
const ctaSubheadline = isEs
  ? "Envíe los datos de su operación y obtenga una revisión gratuita de encaje con prestamistas."
  : "Submit your deal inputs and get a free lender-fit review.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": ["WebApplication", "SoftwareApplication"],
  name: h1,
  description,
  url: canonicalUrl,
  applicationCategory: "FinanceApplication",
  isAccessibleForFree: true,
  inLanguage: isEs ? "es-US" : "en-US",
  dateModified: lastUpdated,
  provider: { "@id": `${SITE_URL}/#organization` },
};

const webPageSchema = buildWebPageSchema({
  name: h1,
  description,
  url: canonicalUrl,
  dateModified: lastUpdated,
});

const faqSchema = faqList.length > 0 ? buildFaqSchema(faqList) : null;
const extrasArray = Array.isArray(extraSchema) ? extraSchema : extraSchema ? [extraSchema] : [];
const schema = [webPageSchema, softwareSchema, ...(faqSchema ? [faqSchema] : []), ...extrasArray];
const relatedLinks = await getRelatedLinks({
  kind: "tool",
  slug: toolSlug,
  title: h1,
  description,
  keywords,
  relatedGuides,
  relatedComparisons,
  relatedLoanTypes,
  relatedPropertyTypes,
  relatedInvestorProfiles,
  relatedBlog,
  limit: 6,
});
---

<DefaultLayout
  title={title}
  description={description}
  schema={schema}
  image={getOgImageForKind("tool")}
  canonical={toolPath}
  keywords={keywords}
  enPath={resolvedEnPath}
  esPath={resolvedEsPath}
>
  <Breadcrumbs
    crumbs={
      isEs
        ? [
            { label: "Inicio", href: "/es" },
            { label: "Herramientas", href: "/es/tools" },
            { label: h1, href: toolPath },
          ]
        : [
            { label: "Home", href: "/" },
            { label: "Tools", href: "/tools" },
            { label: h1, href: toolPath },
          ]
    }
  />

  <header class="container pb-4 pt-2">
    <p class="text-xs font-bold uppercase tracking-wider text-accent">{resolvedKicker}</p>
    <h1 class="mt-2 text-4xl font-bold text-foreground lg:text-5xl">{h1}</h1>
    {tagline && <p class="mt-3 max-w-3xl text-lg text-muted-foreground">{tagline}</p>}
    <p class="mt-2 text-xs text-muted-foreground">{lastUpdatedLabel} <time datetime={lastUpdated}>{lastUpdated}</time></p>
  </header>

  <section class="container grid gap-8 py-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-8">
      <AnswerCapsule
        question={h1}
        answer={tagline ?? description}
        label={isEs ? "Respuesta rápida" : "Quick answer"}
      />
      <slot name="calculator" />
      {relatedLinks.length > 0 && (
        <RelatedReading links={relatedLinks} heading={relatedHeading} />
      )}
      <slot name="content" />
    </div>
    <aside class="lg:col-span-1 space-y-6">
      <slot name="sidebar" />
      <CtaCard
        headline={ctaHeadline}
        subheadline={ctaSubheadline}
        sourceContext={`tool:${toolSlug}`}
        variant="compact"
      />
    </aside>
  </section>

  {
    faqList.length > 0 && (
      <section class="container py-12">
        <h2 class="mb-6 text-3xl font-bold text-foreground" id="faq">{faqHeading}</h2>
        <FaqAccordion items={faqList} />
      </section>
    )
  }
</DefaultLayout>
