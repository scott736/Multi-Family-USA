---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-border rounded-lg border border-border bg-card">
  {items.map((item, i) => (
    <details class="group" open={i === 0}>
      <summary class="flex w-full cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left list-none [&::-webkit-details-marker]:hidden">
        <span class="text-base font-semibold text-foreground">{item.q}</span>
        <svg class="size-5 shrink-0 text-muted-foreground transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </summary>
      <div
        class="px-5 pb-4 text-sm leading-relaxed text-muted-foreground [&_a]:font-semibold [&_a]:text-primary [&_a]:underline [&_a]:decoration-accent [&_a]:underline-offset-4"
        set:html={item.a}
      />
    </details>
  ))}
</div>
