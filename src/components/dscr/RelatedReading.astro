---
import RelatedLinks from "@/components/dscr/RelatedLinks.astro";
import type { RelatedGroup, RelatedLink } from "@/lib/related-links";
import { getLangFromUrl } from "@/i18n/utils";

interface Props {
  links?: RelatedLink[];
  groups?: RelatedGroup[];
  heading?: string;
  intro?: string;
  className?: string;
}

const lang = getLangFromUrl(Astro.url);
const defaultHeading = lang === "es" ? "Recursos relacionados" : "Related Resources";

const { links, groups, heading = defaultHeading, intro, className } = Astro.props;
---

<RelatedLinks links={links} groups={groups} heading={heading} intro={intro} className={className} />
