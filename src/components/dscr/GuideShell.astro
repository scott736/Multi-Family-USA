---
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import CtaCard from "@/components/dscr/CtaCard.astro";
import FaqAccordion from "@/components/dscr/FaqAccordion.astro";
import RelatedReading from "@/components/dscr/RelatedReading.astro";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import {
  buildBlogRelatedGroups,
  getRelatedLinks,
  type ContentKind,
  type RelatedGroup,
} from "@/lib/related-links";
import { getLangFromUrl } from "@/i18n/utils";

import { buildFaqSchema, SITE_URL } from "../../consts";

interface Faq {
  q: string;
  a: string;
}

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  kicker?: string;
  lastUpdated?: string;
  publishedDate?: string;
  author?: string;
  reviewer?: string;
  readTime?: number;
  crumbs: Crumb[];
  faqs?: Faq[];
  canonicalSlug?: string;
  image?: string;
  keywords?: string[];
  section?: string;
  extraSchema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  relatedKind?: ContentKind;
  relatedSlug?: string;
  relatedCategory?: string;
  relatedStateCode?: string;
  relatedStateName?: string;
  relatedTools?: string[];
  relatedGuides?: string[];
  relatedStates?: string[];
  relatedCities?: string[];
  relatedLoanTypes?: string[];
  relatedPropertyTypes?: string[];
  relatedComparisons?: string[];
  relatedInvestorProfiles?: string[];
  relatedBlog?: string[];
  relatedGroups?: RelatedGroup[];
  enPath?: string;
  esPath?: string;
  includeSpanish?: boolean;
}

const {
  title,
  description,
  h1,
  kicker,
  lastUpdated,
  publishedDate,
  author = "Multi-Family USA Editorial Team",
  reviewer,
  readTime,
  crumbs,
  faqs = [],
  canonicalSlug,
  image,
  keywords,
  section,
  extraSchema,
  noindex,
  relatedKind,
  relatedSlug,
  relatedCategory,
  relatedStateCode,
  relatedStateName,
  relatedTools,
  relatedGuides,
  relatedStates,
  relatedCities,
  relatedLoanTypes,
  relatedPropertyTypes,
  relatedComparisons,
  relatedInvestorProfiles,
  relatedBlog,
  relatedGroups: relatedGroupsProp,
  enPath,
  esPath,
  includeSpanish,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const faqList = Array.isArray(faqs) ? faqs : [];
const canonical = canonicalSlug ? `${SITE_URL}${canonicalSlug}` : undefined;
const relatedLinks =
  relatedKind && relatedSlug
    ? await getRelatedLinks({
        kind: relatedKind,
        slug: relatedSlug,
        title: h1,
        description,
        keywords,
        category: relatedCategory,
        stateCode: relatedStateCode,
        stateName: relatedStateName,
        relatedTools,
        relatedGuides,
        relatedStates,
        relatedCities,
        relatedLoanTypes,
        relatedPropertyTypes,
        relatedComparisons,
        relatedInvestorProfiles,
        relatedBlog,
        limit: 6,
      })
    : [];
const fallbackBlogRelatedLinks =
  relatedKind === "blog" && relatedBlog?.length
    ? relatedBlog
        .map((value) => value.trim())
        .filter(Boolean)
        .map((value) => {
          const normalized = value.startsWith("/") ? value : `/blog/${value.replace(/^blog\//, "")}`;
          const href = normalized.endsWith("/") ? normalized : `${normalized}/`;
          const slug = normalized
            .replace(/^\/blog\//, "")
            .replace(/\/$/, "")
            .replace(/\.mdx$/, "");
          const title = slug
            .split("-")
            .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
            .join(" ");
          return {
            href,
            title,
            type: "blog" as const,
          };
        })
    : [];
const effectiveRelatedLinks =
  relatedLinks.length > 0 ? relatedLinks : fallbackBlogRelatedLinks;

const blogRelatedGroups =
  relatedKind === "blog" && !relatedGroupsProp?.length
    ? await buildBlogRelatedGroups({
        lang,
        slug: relatedSlug ?? "",
        relatedTools,
        relatedGuides,
        relatedStates,
        relatedCities,
        relatedLoanTypes,
        relatedPropertyTypes,
        relatedComparisons,
        relatedInvestorProfiles,
        relatedBlog,
      })
    : [];

const relatedGroups =
  relatedGroupsProp && relatedGroupsProp.length > 0
    ? relatedGroupsProp
    : blogRelatedGroups;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: h1,
  description,
  ...(canonical ? { url: canonical, mainEntityOfPage: canonical } : {}),
  datePublished: publishedDate ?? lastUpdated ?? "2026-05-24",
  dateModified: lastUpdated ?? publishedDate ?? "2026-05-24",
  author: {
    "@type": "Organization",
    name: author,
  },
  ...(keywords?.length ? { keywords: keywords.join(", ") } : {}),
};

const faqSchema = faqList.length > 0 ? buildFaqSchema(faqList) : null;
const extrasArray = Array.isArray(extraSchema) ? extraSchema : extraSchema ? [extraSchema] : [];
const schema = [articleSchema, ...(faqSchema ? [faqSchema] : []), ...extrasArray];
---

<DefaultLayout
  title={title}
  description={description}
  schema={schema}
  image={image}
  canonical={canonicalSlug}
  keywords={keywords}
  noindex={noindex}
  enPath={enPath}
  esPath={esPath}
  includeSpanish={includeSpanish}
>
  <Breadcrumbs crumbs={crumbs} />

  <article class="container grid gap-10 py-8 lg:grid-cols-4">
    <header class="lg:col-span-4 max-w-4xl">
      {kicker && <p class="text-xs font-bold uppercase tracking-wider text-accent">{kicker}</p>}
      <h1 class="mt-2 text-4xl font-bold text-foreground lg:text-5xl">{h1}</h1>
      <p class="sr-only">{description}</p>
      <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
        <span>By <strong>{author}</strong></span>
        {reviewer && <span>Reviewed by {reviewer}</span>}
        {lastUpdated && <span>Updated <time datetime={lastUpdated}>{lastUpdated}</time></span>}
        {readTime && <span>{readTime} min read</span>}
        {section && <span>{section}</span>}
      </div>
    </header>

    <div class="prose-dscr lg:col-span-3">
      <slot />
      {(relatedGroups.length > 0 || effectiveRelatedLinks.length > 0) && (
        <div class="my-10 lg:hidden">
          <RelatedReading
            groups={relatedGroups.length > 0 ? relatedGroups : undefined}
            links={relatedGroups.length > 0 ? undefined : effectiveRelatedLinks}
          />
        </div>
      )}
      {faqList.length > 0 && (
        <>
          <h2 class="!mt-12" id="faq">Frequently asked questions</h2>
          <FaqAccordion items={faqList} />
        </>
      )}
    </div>

    <aside class="hidden lg:block lg:col-span-1">
      <div class="lg:sticky lg:top-24 space-y-6">
        <CtaCard variant="compact" sourceContext={`guide:${canonicalSlug ?? title}`} />
        {(relatedGroups.length > 0 || effectiveRelatedLinks.length > 0) && (
          <RelatedReading
            groups={relatedGroups.length > 0 ? relatedGroups : undefined}
            links={relatedGroups.length > 0 ? undefined : effectiveRelatedLinks}
          />
        )}
      </div>
    </aside>
  </article>
</DefaultLayout>
