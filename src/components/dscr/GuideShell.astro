---
import Breadcrumbs from "@/components/dscr/Breadcrumbs.astro";
import CtaCard from "@/components/dscr/CtaCard.astro";
import FaqAccordion from "@/components/dscr/FaqAccordion.astro";
import RelatedReading from "@/components/dscr/RelatedReading.astro";
import { getLangFromUrl } from "@/i18n/utils";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { getOgImageForKind } from "@/lib/og-image";
import {
  buildBlogRelatedGroups,
  type ContentKind,
  getRelatedLinks,
  type RelatedGroup,
} from "@/lib/related-links";

import {
  buildArticleSchema,
  buildFaqSchema,
  buildFinancialProductSchema,
  buildWebPageSchema,
  SITE_URL,
} from "../../consts";
import { getAuthorByName, getPersonId } from "../../lib/authors";

interface Faq {
  q: string;
  a: string;
}

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  kicker?: string;
  lastUpdated?: string;
  publishedDate?: string;
  author?: string;
  reviewer?: string;
  readTime?: number;
  crumbs: Crumb[];
  faqs?: Faq[];
  canonicalSlug?: string;
  image?: string;
  keywords?: string[];
  section?: string;
  extraSchema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  relatedKind?: ContentKind;
  relatedSlug?: string;
  relatedCategory?: string;
  relatedStateCode?: string;
  relatedStateName?: string;
  relatedTools?: string[];
  relatedGuides?: string[];
  relatedStates?: string[];
  relatedCities?: string[];
  relatedLoanTypes?: string[];
  relatedPropertyTypes?: string[];
  relatedComparisons?: string[];
  relatedInvestorProfiles?: string[];
  relatedBlog?: string[];
  relatedGroups?: RelatedGroup[];
  enPath?: string;
  esPath?: string;
  includeSpanish?: boolean;
}

const {
  title,
  description,
  h1,
  kicker,
  lastUpdated,
  publishedDate,
  author = "Multi-Family USA Editorial Team",
  reviewer,
  readTime,
  crumbs,
  faqs = [],
  canonicalSlug,
  image,
  keywords,
  section,
  extraSchema,
  noindex,
  relatedKind,
  relatedSlug,
  relatedCategory,
  relatedStateCode,
  relatedStateName,
  relatedTools,
  relatedGuides,
  relatedStates,
  relatedCities,
  relatedLoanTypes,
  relatedPropertyTypes,
  relatedComparisons,
  relatedInvestorProfiles,
  relatedBlog,
  relatedGroups: relatedGroupsProp,
  enPath,
  esPath,
  includeSpanish,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const faqList = Array.isArray(faqs) ? faqs : [];
const canonical = canonicalSlug ? `${SITE_URL}${canonicalSlug}` : undefined;
const relatedLinks =
  relatedKind && relatedSlug
    ? await getRelatedLinks({
        kind: relatedKind,
        slug: relatedSlug,
        title: h1,
        description,
        keywords,
        category: relatedCategory,
        stateCode: relatedStateCode,
        stateName: relatedStateName,
        relatedTools,
        relatedGuides,
        relatedStates,
        relatedCities,
        relatedLoanTypes,
        relatedPropertyTypes,
        relatedComparisons,
        relatedInvestorProfiles,
        relatedBlog,
        limit: 6,
      })
    : [];
const fallbackBlogRelatedLinks =
  relatedKind === "blog" && relatedBlog?.length
    ? relatedBlog
        .map((value) => value.trim())
        .filter(Boolean)
        .map((value) => {
          const normalized = value.startsWith("/") ? value : `/blog/${value.replace(/^blog\//, "")}`;
          const href = normalized.endsWith("/") ? normalized : `${normalized}/`;
          const slug = normalized
            .replace(/^\/blog\//, "")
            .replace(/\/$/, "")
            .replace(/\.mdx$/, "");
          const title = slug
            .split("-")
            .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
            .join(" ");
          return {
            href,
            title,
            type: "blog" as const,
          };
        })
    : [];
const effectiveRelatedLinks =
  relatedLinks.length > 0 ? relatedLinks : fallbackBlogRelatedLinks;

const blogRelatedGroups =
  relatedKind === "blog" && !relatedGroupsProp?.length
    ? await buildBlogRelatedGroups({
        lang,
        slug: relatedSlug ?? "",
        relatedTools,
        relatedGuides,
        relatedStates,
        relatedCities,
        relatedLoanTypes,
        relatedPropertyTypes,
        relatedComparisons,
        relatedInvestorProfiles,
        relatedBlog,
      })
    : [];

const relatedGroups =
  relatedGroupsProp && relatedGroupsProp.length > 0
    ? relatedGroupsProp
    : blogRelatedGroups;

const pageLanguage = lang === "es" ? "es-US" : "en-US";
const modifiedDate = lastUpdated ?? publishedDate ?? "2026-05-24";
const published = publishedDate ?? lastUpdated ?? "2026-05-24";

const authorPerson = getAuthorByName(author);
const reviewerPerson = reviewer ? getAuthorByName(reviewer) : undefined;
const authorProfilePath = authorPerson ? `/team/${authorPerson.slug}` : undefined;
const reviewerProfilePath = reviewerPerson ? `/team/${reviewerPerson.slug}` : undefined;
const ogImage = getOgImageForKind(relatedKind, image);

const webPageSchema =
  canonical && canonicalSlug
    ? buildWebPageSchema({
        name: h1,
        description,
        url: canonical,
        inLanguage: pageLanguage,
        dateModified: modifiedDate,
        ...(section ? { about: section } : {}),
      })
    : null;

const articleSchema =
  canonical && canonicalSlug
    ? buildArticleSchema({
        headline: h1,
        description,
        url: canonical,
        datePublished: published,
        dateModified: modifiedDate,
        authorName: author,
        authorId: authorPerson ? getPersonId(authorPerson.slug) : undefined,
        reviewerName: reviewer,
        reviewerId: reviewerPerson ? getPersonId(reviewerPerson.slug) : undefined,
        keywords,
        image: ogImage,
        inLanguage: pageLanguage,
        articleSection: section ?? kicker,
        articleType: relatedKind === "blog" ? "BlogPosting" : "Article",
      })
    : null;

const financialProductSchema =
  relatedKind === "loanType" && canonical && canonicalSlug
    ? buildFinancialProductSchema({
        name: h1,
        description,
        url: canonical,
      })
    : null;

const faqSchema = faqList.length > 0 ? buildFaqSchema(faqList) : null;
const extrasArray = Array.isArray(extraSchema) ? extraSchema : extraSchema ? [extraSchema] : [];
const schema = [
  ...(webPageSchema ? [webPageSchema] : []),
  ...(articleSchema ? [articleSchema] : []),
  ...(financialProductSchema ? [financialProductSchema] : []),
  ...(faqSchema ? [faqSchema] : []),
  ...extrasArray,
];
---

<DefaultLayout
  title={title}
  description={description}
  schema={schema}
  image={ogImage}
  canonical={canonicalSlug}
  keywords={keywords}
  noindex={noindex}
  enPath={enPath}
  esPath={esPath}
  includeSpanish={includeSpanish}
>
  <Breadcrumbs crumbs={crumbs} />

  <article class="container grid gap-10 py-8 lg:grid-cols-4">
    <header class="lg:col-span-4 max-w-4xl">
      {kicker && <p class="text-xs font-bold uppercase tracking-wider text-accent">{kicker}</p>}
      <h1 class="mt-2 text-4xl font-bold text-foreground lg:text-5xl">{h1}</h1>
      <p class="sr-only">{description}</p>
      <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
        <span>
          By{" "}
          {authorProfilePath ? (
            <a href={authorProfilePath} rel="author" class="font-semibold text-foreground hover:text-accent">
              {author}
            </a>
          ) : (
            <strong>{author}</strong>
          )}
        </span>
        {reviewer && (
          <span>
            Reviewed by{" "}
            {reviewerProfilePath ? (
              <a href={reviewerProfilePath} rel="author" class="font-semibold text-foreground hover:text-accent">
                {reviewer}
              </a>
            ) : (
              reviewer
            )}
          </span>
        )}
        {publishedDate && (
          <span>
            Published <time datetime={publishedDate}>{publishedDate}</time>
          </span>
        )}
        {lastUpdated && publishedDate !== lastUpdated && (
          <span>Updated <time datetime={lastUpdated}>{lastUpdated}</time></span>
        )}
        {lastUpdated && !publishedDate && (
          <span>Updated <time datetime={lastUpdated}>{lastUpdated}</time></span>
        )}
        {readTime && <span>{readTime} min read</span>}
        {section && <span>{section}</span>}
      </div>
    </header>

    <div class="prose-dscr lg:col-span-3">
      <slot />
      <div class="my-10 lg:hidden">
        <CtaCard
          variant="compact"
          sourceContext={`guide-mobile:${canonicalSlug ?? title}`}
        />
      </div>
      {(relatedGroups.length > 0 || effectiveRelatedLinks.length > 0) && (
        <div class="my-10 lg:hidden">
          <RelatedReading
            groups={relatedGroups.length > 0 ? relatedGroups : undefined}
            links={relatedGroups.length > 0 ? undefined : effectiveRelatedLinks}
          />
        </div>
      )}
      {faqList.length > 0 && (
        <>
          <h2 class="!mt-12" id="faq">Frequently asked questions</h2>
          <FaqAccordion items={faqList} />
        </>
      )}
    </div>

    <aside class="hidden lg:block lg:col-span-1">
      <div class="lg:sticky lg:top-24 space-y-6">
        <CtaCard variant="compact" sourceContext={`guide:${canonicalSlug ?? title}`} />
        {(relatedGroups.length > 0 || effectiveRelatedLinks.length > 0) && (
          <RelatedReading
            groups={relatedGroups.length > 0 ? relatedGroups : undefined}
            links={relatedGroups.length > 0 ? undefined : effectiveRelatedLinks}
          />
        )}
      </div>
    </aside>
  </article>
</DefaultLayout>
