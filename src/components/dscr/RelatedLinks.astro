---
import type { RelatedLink } from "@/lib/related-links";

interface Props {
  links: RelatedLink[];
  heading?: string;
  className?: string;
}

const {
  links,
  heading = "Related Reading",
  className = "",
} = Astro.props;
---

{
  links.length > 0 && (
    <section
      class:list={[
        "not-prose rounded-2xl border border-border bg-secondary/30 p-6",
        className,
      ]}
      aria-labelledby="related-links-heading"
    >
      <h2 id="related-links-heading" class="text-lg font-bold text-foreground">
        {heading}
      </h2>
      <ul class="mt-4 space-y-3">
        {links.map((link) => (
          <li>
            <a href={link.href} class="group block rounded-lg border border-border bg-card px-4 py-3 hover:border-accent">
              <p class="text-xs font-semibold uppercase tracking-wide text-accent">
                {link.type.replace("-", " ")}
              </p>
              <p class="mt-1 text-sm font-semibold text-foreground group-hover:text-primary">{link.title}</p>
              {link.description && <p class="mt-1 text-xs text-muted-foreground line-clamp-2">{link.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
