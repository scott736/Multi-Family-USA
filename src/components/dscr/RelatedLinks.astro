---
import { ArrowUpRight } from "lucide-react";

import { getLangFromUrl } from "@/i18n/utils";
import type { RelatedGroup } from "@/lib/related-links";

interface Props {
  groups: RelatedGroup[];
  heading?: string;
  intro?: string;
}

const lang = getLangFromUrl(Astro.url);
const isEs = lang === "es";

const defaultHeading = isEs ? "Sigue explorando" : "Keep exploring";
const defaultIntro = isEs
  ? "Siguientes pasos seleccionados — ya sea para profundizar en el tema, comparar alternativas o analizar los números."
  : "Hand-picked next steps — whether you want to go deeper on this topic, compare alternatives, or run the numbers.";

const {
  groups,
  heading = defaultHeading,
  intro = defaultIntro,
} = Astro.props;

function truncate(input: string, max = 130): string {
  if (input.length <= max) return input;
  const slice = input.slice(0, max);
  const lastSpace = slice.lastIndexOf(" ");
  return `${slice.slice(0, lastSpace > 80 ? lastSpace : max).trimEnd()}…`;
}
---

{
  groups.length > 0 && (
    <section
      class="not-prose my-14 rounded-2xl border border-border bg-secondary/30 p-6 md:p-8"
      aria-labelledby="related-links-heading"
    >
      <header class="mb-6 max-w-3xl">
        <h2
          id="related-links-heading"
          class="text-2xl font-bold text-foreground md:text-3xl"
        >
          {heading}
        </h2>
        {intro && (
          <p class="mt-2 text-sm text-muted-foreground md:text-base">{intro}</p>
        )}
      </header>

      <div class="space-y-8">
        {groups.map((group) => (
          <div>
            <div class="mb-3 flex items-baseline justify-between gap-4 border-b border-border pb-2">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                {group.label}
              </h3>
              {group.description && (
                <p class="hidden text-xs text-muted-foreground md:block">
                  {group.description}
                </p>
              )}
            </div>
            <ul class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="group flex h-full flex-col gap-2 rounded-lg border border-border bg-card p-4 transition-colors hover:border-accent hover:bg-card/80 focus-visible:border-accent focus-visible:outline-none"
                    data-related-kind={group.label}
                  >
                    <div class="flex items-start justify-between gap-3">
                      <span class="inline-flex rounded-full bg-accent/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-accent">
                        {link.kicker}
                      </span>
                      <ArrowUpRight className="size-4 shrink-0 text-muted-foreground transition-colors group-hover:text-primary" />
                    </div>
                    <h4 class="text-base font-bold leading-snug text-foreground group-hover:text-primary">
                      {link.title}
                    </h4>
                    <p class="mt-auto text-sm leading-snug text-muted-foreground">
                      {truncate(link.description)}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )
}
