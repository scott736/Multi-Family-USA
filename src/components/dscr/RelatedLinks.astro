---
import { ArrowUpRight } from "lucide-react";
import type { RelatedGroup, RelatedLink } from "@/lib/related-links";
import { getLangFromUrl } from "@/i18n/utils";

interface Props {
  links?: RelatedLink[];
  groups?: RelatedGroup[];
  heading?: string;
  intro?: string;
  className?: string;
}

const lang = getLangFromUrl(Astro.url);
const isEs = lang === "es";

const defaultHeading = isEs ? "Sigue explorando" : "Keep exploring";
const defaultIntro = isEs
  ? "Siguientes pasos seleccionados: profundizar en el tema, comparar alternativas o analizar los números."
  : "Hand-picked next steps — go deeper on this topic, compare alternatives, or run the numbers.";

const {
  links = [],
  groups = [],
  heading = defaultHeading,
  intro = defaultIntro,
  className = "",
} = Astro.props;

function truncate(input: string, max = 130): string {
  if (input.length <= max) return input;
  const slice = input.slice(0, max);
  const lastSpace = slice.lastIndexOf(" ");
  return `${slice.slice(0, lastSpace > 80 ? lastSpace : max).trimEnd()}…`;
}

function typeLabel(type: RelatedLink["type"]): string {
  const en: Record<RelatedLink["type"], string> = {
    guide: "Guide",
    tool: "Calculator",
    state: "State",
    city: "City",
    "loan-type": "Loan type",
    "property-type": "Property type",
    comparison: "Comparison",
    "investor-profile": "Investor profile",
    blog: "Blog",
  };
  const es: Record<RelatedLink["type"], string> = {
    guide: "Guía",
    tool: "Calculadora",
    state: "Estado",
    city: "Ciudad",
    "loan-type": "Tipo de préstamo",
    "property-type": "Tipo de propiedad",
    comparison: "Comparación",
    "investor-profile": "Perfil",
    blog: "Blog",
  };
  return (isEs ? es : en)[type];
}

const useGroups = groups.length > 0;
const displayLinks = useGroups ? [] : links;
const hasContent = useGroups || displayLinks.length > 0;
---

{
  hasContent && (
    <section
      class:list={[
        "not-prose rounded-2xl border border-border bg-secondary/30 p-6",
        className,
      ]}
      aria-labelledby="related-links-heading"
    >
      <header class:list={["mb-4", useGroups && "mb-6 max-w-3xl"]}>
        <h2 id="related-links-heading" class="text-lg font-bold text-foreground md:text-2xl">
          {heading}
        </h2>
        {intro && <p class="mt-2 text-sm text-muted-foreground md:text-base">{intro}</p>}
      </header>

      {useGroups ? (
        <div class="space-y-8">
          {groups.map((group) => (
            <div>
              <div class="mb-3 flex items-baseline justify-between gap-4 border-b border-border pb-2">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
                  {group.label}
                </h3>
                {group.description && (
                  <p class="hidden text-xs text-muted-foreground md:block">{group.description}</p>
                )}
              </div>
              <ul class="grid gap-3 md:grid-cols-2">
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="group flex h-full flex-col gap-2 rounded-lg border border-border bg-card p-4 transition-colors hover:border-accent"
                    >
                      <div class="flex items-start justify-between gap-3">
                        <span class="inline-flex rounded-full bg-accent/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-accent">
                          {link.kicker}
                        </span>
                        <ArrowUpRight className="size-4 shrink-0 text-muted-foreground group-hover:text-primary" />
                      </div>
                      <h4 class="text-base font-bold leading-snug text-foreground group-hover:text-primary">
                        {link.title}
                      </h4>
                      <p class="mt-auto text-sm leading-snug text-muted-foreground">
                        {truncate(link.description)}
                      </p>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <ul class="mt-4 space-y-3">
          {displayLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="group block rounded-lg border border-border bg-card px-4 py-3 hover:border-accent"
              >
                <p class="text-xs font-semibold uppercase tracking-wide text-accent">
                  {typeLabel(link.type)}
                </p>
                <p class="mt-1 text-sm font-semibold text-foreground group-hover:text-primary">
                  {link.title}
                </p>
                {link.description && (
                  <p class="mt-1 text-xs text-muted-foreground line-clamp-2">{link.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  )
}
