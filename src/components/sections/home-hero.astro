---
import LeadForm from "@/components/forms/LeadForm.astro";

interface CtaLink {
  href: string;
  label: string;
}

interface StatItem {
  label: string;
  value: string;
  sub: string;
  accent?: boolean;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaPrimary: CtaLink;
  ctaSecondary: CtaLink;
  pills: string[];
  formSourceContext: string;
  stats?: StatItem[];
}

const {
  eyebrow,
  title,
  description,
  ctaPrimary,
  ctaSecondary,
  pills,
  formSourceContext,
  stats = [
    { label: "Coverage", value: "50+", sub: "states & DC" },
    { label: "Tools", value: "20+", sub: "underwriting calcs" },
    { label: "Response", value: "~1 hr", sub: "deal review turn", accent: true },
  ],
} = Astro.props;
---

<section class="home-hero relative overflow-hidden border-b border-border">
  <!-- Layered atmosphere -->
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_20%_0%,hsl(var(--accent)/0.09),transparent_55%),radial-gradient(ellipse_60%_50%_at_90%_100%,hsl(var(--primary)/0.06),transparent_50%),linear-gradient(145deg,hsl(var(--secondary)/0.85)_0%,hsl(var(--background))_45%,hsl(var(--accent)/0.04)_100%)]"
    aria-hidden="true"
  />
  <div
    class="home-hero-grid pointer-events-none absolute inset-0 opacity-[0.35]"
    aria-hidden="true"
  />
  <div class="home-hero-grain pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true" />
  <div
    class="pointer-events-none absolute -right-24 top-[-10%] size-[min(32rem,75vw)] rounded-full bg-accent/14 blur-[80px]"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute -bottom-32 -left-24 size-96 rounded-full bg-primary/[0.05] blur-[72px]"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute right-[8%] top-[18%] hidden h-px w-32 bg-gradient-to-r from-transparent via-accent/40 to-transparent lg:block"
    aria-hidden="true"
  />

  <div class="container relative py-12 md:py-16 lg:py-[4.5rem]">
    <div
      class="grid items-center gap-10 lg:grid-cols-[1fr_minmax(0,420px)] lg:gap-12 xl:grid-cols-[1.08fr_440px] xl:gap-14"
    >
      <div class="home-hero-stagger space-y-8 lg:pr-4">
        <div class="space-y-5">
          <div class="flex items-center gap-3">
            <span class="home-hero-accent-rule" aria-hidden="true"></span>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent">{eyebrow}</p>
          </div>
          <h1 class="max-w-[18ch] text-[2.25rem] font-bold leading-[1.06] tracking-tight sm:text-4xl md:text-[2.75rem] lg:text-[3.5rem] lg:leading-[1.04]">
            {title}
          </h1>
          <p class="max-w-xl text-base leading-relaxed text-muted-foreground md:text-lg md:leading-relaxed">
            {description}
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            href={ctaPrimary.href}
            class="home-hero-cta-primary group inline-flex items-center gap-2 rounded-xl bg-accent px-6 py-3.5 text-base font-bold text-accent-foreground shadow-lg shadow-accent/20 transition duration-300 hover:-translate-y-0.5 hover:bg-accent/92 hover:shadow-xl hover:shadow-accent/30"
          >
            {ctaPrimary.label}
            <svg
              class="size-4 transition-transform duration-300 group-hover:translate-x-0.5"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href={ctaSecondary.href}
            class="inline-flex items-center rounded-xl border border-border/80 bg-card/60 px-6 py-3.5 text-base font-semibold backdrop-blur-md transition duration-300 hover:-translate-y-0.5 hover:border-primary/25 hover:bg-card/90"
          >
            {ctaSecondary.label}
          </a>
        </div>

        <div class="flex flex-wrap gap-2.5">
          {
            pills.map((pill) => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-border/70 bg-card/55 px-3.5 py-1.5 text-xs font-semibold text-muted-foreground backdrop-blur-sm">
                <svg class="size-3 text-success" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path
                    d="M2.5 6l2.5 2.5 4.5-5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
                {pill}
              </span>
            ))
          }
        </div>

        <div class="hidden border-t border-border/60 pt-6 lg:block">
          <dl class="grid grid-cols-3 gap-6">
            {
              stats.map((stat) => (
                <div>
                  <dt class="text-[10px] font-bold uppercase tracking-[0.16em] text-muted-foreground">{stat.label}</dt>
                  <dd
                    class:list={[
                      "mt-1 text-2xl font-bold tabular-nums",
                      stat.accent ? "text-accent" : "text-foreground",
                    ]}
                  >
                    {stat.value}
                  </dd>
                  <dd class="text-xs text-muted-foreground">{stat.sub}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>

      <div class="home-hero-form-wrap relative">
        <LeadForm variant="hero" sourceContext={formSourceContext} />
      </div>
    </div>
  </div>
</section>
