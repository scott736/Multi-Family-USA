---
import { getLangFromUrl } from "@/i18n/utils";

interface Props {
  lang?: "en" | "es";
}

const { lang: langProp } = Astro.props;
const lang = (langProp || getLangFromUrl(Astro.url)) as "en" | "es";
const isEs = lang === "es";

const bookingUrl = isEs ? "/es/book-strategy-call/" : "/book-strategy-call/";
const dealUrl = isEs ? "/es/deal-review/" : "/deal-review/";
const title = isEs
  ? "¿Listo para llevar esto a su operación?"
  : "Ready to Take This to Your Deal?";
const description = isEs
  ? "Multi-Family USA ayuda a sponsors a estructurar deuda comercial multifamiliar y revisar lender fit."
  : "Multi-Family USA helps sponsors structure commercial multifamily debt and pressure-test lender fit.";
const primaryLabel = isEs ? "Reservar llamada estratégica" : "Book a Strategy Call";
const secondaryLabel = isEs ? "Revisión de operación" : "Free Deal Review";
---

<section class="my-12 border-t border-border pt-10" data-pagefind-ignore>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">{title}</h2>
    <p class="mx-auto mt-3 max-w-lg text-muted-foreground">{description}</p>
    <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
      <a
        href={bookingUrl}
        class="inline-flex h-10 items-center justify-center gap-1 rounded-md bg-accent px-6 py-2.5 text-sm font-medium text-accent-foreground shadow-md shadow-accent/20 hover:opacity-95"
        data-analytics-location="blog-closing-primary"
      >
        {primaryLabel}
      </a>
      <a
        href={dealUrl}
        class="inline-flex h-10 items-center justify-center gap-1 rounded-md border border-border bg-card px-6 py-2.5 text-sm font-medium text-foreground hover:border-accent"
        data-analytics-location="blog-closing-secondary"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
