---
import { SITE_PHONE_HREF } from "../../consts";
---

<div
  data-sticky-cta
  class="fixed inset-x-0 bottom-0 z-40 flex gap-0 border-t border-border bg-background/95 backdrop-blur transition-transform duration-300 md:hidden translate-y-full"
>
  <a
    href={SITE_PHONE_HREF}
    class="flex flex-1 items-center justify-center gap-2 border-r border-border py-3 text-sm font-semibold text-foreground"
  >
    Call
  </a>
  <a
    href="/book-strategy-call"
    class="flex flex-1 items-center justify-center gap-2 border-r border-border py-3 text-sm font-semibold text-foreground"
  >
    Book
  </a>
  <a
    href="/deal-review"
    class="flex flex-1 items-center justify-center gap-2 bg-accent py-3 text-sm font-bold text-accent-foreground"
  >
    Free Deal Review
  </a>
</div>

<script is:inline>
  (() => {
    const el = document.querySelector("[data-sticky-cta]");
    if (!el) return;
    const update = () => el.classList.toggle("translate-y-full", window.scrollY <= 500);
    update();
    window.addEventListener("scroll", update, { passive: true });
  })();
</script>
