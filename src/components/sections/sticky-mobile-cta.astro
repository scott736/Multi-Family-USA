---
import { SITE_PHONE_HREF } from "../../consts";

const isEs = Astro.url.pathname === "/es" || Astro.url.pathname.startsWith("/es/");
const bookHref = isEs ? "/es/book-strategy-call" : "/book-strategy-call";
const dealHref = isEs ? "/es/deal-review" : "/deal-review";
---

<div
  data-sticky-cta
  class="fixed inset-x-0 bottom-0 z-40 px-3 pb-[max(env(safe-area-inset-bottom),0.75rem)] transition-transform duration-300 translate-y-[120%] md:hidden"
>
  <div
    class="flex items-stretch gap-1.5 rounded-2xl border border-border/80 bg-background/95 p-1.5 shadow-2xl shadow-primary/20 backdrop-blur-md"
  >
    <a
      href={bookHref}
      class="flex flex-[1.35] items-center justify-center gap-1.5 rounded-xl bg-accent px-2 py-3 text-sm font-bold text-accent-foreground shadow-md shadow-accent/25"
      data-analytics-location="sticky-mobile"
    >
      <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
      </svg>
      {isEs ? "Reservar llamada" : "Book Free Call"}
    </a>
    <a
      href={dealHref}
      class="flex flex-1 items-center justify-center gap-1.5 rounded-xl border border-border bg-card px-2 py-3 text-xs font-semibold text-foreground"
      data-analytics-location="sticky-mobile"
    >
      {isEs ? "Revisión" : "Deal Review"}
    </a>
    <a
      href={SITE_PHONE_HREF}
      aria-label={isEs ? "Llamar ahora" : "Call now"}
      class="flex w-12 shrink-0 items-center justify-center rounded-xl border border-border bg-card text-foreground"
      data-analytics-location="sticky-mobile"
    >
      <svg class="size-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
    </a>
  </div>
</div>

<script is:inline>
  (() => {
    const el = document.querySelector("[data-sticky-cta]");
    if (!el) return;
    const path = window.location.pathname;
    const hideOnFormPages =
      path.includes("/deal-review") ||
      path.includes("/book-strategy-call") ||
      path.includes("/thank-you");
    const update = () => {
      const scrolled = window.scrollY > 500;
      el.classList.toggle("translate-y-[120%]", !scrolled || hideOnFormPages);
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  })();
</script>
