---
import { ChevronRight, Phone, FileCheck, Calendar } from "lucide-react";

interface Step {
  title: string;
  description: string;
  icon: "Phone" | "FileCheck" | "Calendar";
}

interface Props {
  title: string;
  description: string;
  subtitle?: string;
  steps?: Step[];
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  description,
  subtitle,
  steps = [
    { icon: "Phone", title: "Strategy Call", description: "Discuss your deal, goals, and ideal loan structure." },
    { icon: "FileCheck", title: "Get Pre-Approved", description: "We line you up with the right DSCR program for your scenario." },
    { icon: "Calendar", title: "Close Your Deal", description: "Fast closings with a U.S. loan officer guiding every step." },
  ],
  primaryCtaLabel = "Book A Strategy Call",
  primaryCtaHref = "#loan-officers",
  secondaryCtaLabel = "Get Matched With A Lender",
  secondaryCtaHref = "/get-matched",
} = Astro.props as Props;

const iconMap = {
  Phone: Phone,
  FileCheck: FileCheck,
  Calendar: Calendar,
} as const;
---

<section class="border-b border-border text-center">
  <div class="container border-x border-border mx-auto pb-12 pt-16 text-center md:pt-20 lg:pt-28">
    {subtitle && (
      <p class="text-muted-foreground mb-2 text-sm font-medium uppercase tracking-wider">
        {subtitle}
      </p>
    )}
    <h1
      class="mx-auto max-w-[1000px] text-balance text-[2.5rem] font-bold leading-[1.2] tracking-[-1.6px] md:text-[4rem] md:!leading-[1.15] md:tracking-[-4.32px] lg:text-7xl"
    >
      {title}
    </h1>
    <p
      class="text-muted-foreground mx-auto mt-5 max-w-[700px] leading-[1.5] tracking-[-0.32px] md:mt-6"
    >
      {description}
    </p>

    <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center md:mt-8 lg:mt-10">
      <a
        href={primaryCtaHref}
        class="inline-flex h-9 items-center justify-center gap-1 whitespace-nowrap rounded-md bg-accent px-4 py-2 text-sm font-medium text-accent-foreground shadow-md transition hover:bg-accent/90 hover:shadow-lg hover:-translate-y-0.5 active:shadow-sm active:translate-y-0"
      >
        {primaryCtaLabel}
        <ChevronRight className="size-4" />
      </a>
      <a
        href={secondaryCtaHref}
        class="inline-flex h-9 items-center justify-center gap-1 whitespace-nowrap rounded-md border border-input bg-background px-4 py-2 text-sm font-medium shadow-sm transition hover:bg-secondary hover:shadow-md hover:-translate-y-0.5 active:shadow-none active:translate-y-0"
      >
        {secondaryCtaLabel}
        <ChevronRight className="size-4" />
      </a>
    </div>

    <div class="mt-10 md:mt-12 lg:mt-14">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-3xl mx-auto">
        {
          steps.map((step, index) => {
            const Icon = iconMap[step.icon];
            return (
              <div class="relative flex flex-col items-center p-5 rounded-xl border border-border bg-background/80">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 size-6 rounded-full bg-primary text-primary-foreground text-xs font-bold flex items-center justify-center">
                  {index + 1}
                </div>
                <Icon className="size-6 mb-2 text-primary" />
                <p class="font-semibold text-sm mb-1">{step.title}</p>
                <p class="text-xs text-muted-foreground">{step.description}</p>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
