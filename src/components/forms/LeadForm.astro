---
import LeadFormReact from "./LeadForm";

interface Props {
  variant?: "full" | "compact" | "hero" | "premium";
  sourcePage?: string;
  sourceContext?: string;
  headline?: string;
  subheadline?: string;
  submitLabel?: string;
  className?: string;
  lang?: "en" | "es";
  /** Override Astro island hydration timing (defaults from variant). */
  hydrate?: "load" | "idle" | "visible";
}

const {
  variant = "full",
  sourcePage = Astro.url.pathname,
  sourceContext,
  headline,
  subheadline,
  submitLabel,
  className = "",
  lang = Astro.url.pathname.startsWith("/es") ? "es" : "en",
  hydrate,
} = Astro.props;

const hydration =
  hydrate ??
  (variant === "premium" || variant === "full"
    ? "load"
    : variant === "hero"
      ? "idle"
      : "visible");

const sharedProps = {
  variant,
  sourcePage,
  sourceContext,
  headline,
  subheadline,
  submitLabel,
  className,
  lang,
};
---

{
  hydration === "load" ? (
    <LeadFormReact {...sharedProps} client:load />
  ) : hydration === "idle" ? (
    <LeadFormReact {...sharedProps} client:idle />
  ) : (
    <LeadFormReact {...sharedProps} client:visible />
  )
}
