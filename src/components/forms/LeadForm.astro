---
import LeadFormReact from "./LeadForm";

interface Props {
  variant?: "full" | "compact" | "hero" | "premium";
  sourcePage?: string;
  sourceContext?: string;
  headline?: string;
  subheadline?: string;
  submitLabel?: string;
  className?: string;
  lang?: "en" | "es";
}

const {
  variant = "full",
  sourcePage = Astro.url.pathname,
  sourceContext,
  headline,
  subheadline,
  submitLabel,
  className = "",
  lang = Astro.url.pathname.startsWith("/es") ? "es" : "en",
} = Astro.props;
---

<LeadFormReact
  variant={variant}
  sourcePage={sourcePage}
  sourceContext={sourceContext}
  headline={headline}
  subheadline={subheadline}
  submitLabel={submitLabel}
  className={className}
  lang={lang}
  client:load
/>
